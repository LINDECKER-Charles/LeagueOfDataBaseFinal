# Symfony framework defaults (committed, NON-secret).
#
# Load order (later wins): .env  <  .env.local  <  .env.$APP_ENV  <  .env.$APP_ENV.local
# Real environment variables win over every .env file.
#
# NO SECRET VALUE HERE. Secrets are provided as real env:
#   * Docker: repo-root .env / .env.test / .env.prod (git-ignored), mapped in compose.yaml
#   * Host (non-docker) dev/test: app/.env.local / app/.env.test.local (git-ignored)
# See docs/github-actions-secrets.md.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
# Reverse-proxy trust (Caddy -> nginx -> php-fpm). REMOTE_ADDR = trust the direct
# upstream. Prod sets this as a real env via compose.yaml; this is the dev/test default.
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
###< symfony/framework-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> app/go-fetcher ###
# Go fetch gateway. Overridden to http://go-fetcher:8085 inside the Docker network.
GO_FETCHER_URL=http://127.0.0.1:8085
###< app/go-fetcher ###

###> app/minio ###
# S3-compatible object storage (content-addressed image blobs).
# MINIO_SECRET_KEY is a secret: provided via real env (see header).
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_REGION=us-east-1
MINIO_BUCKET=ddragon
MINIO_ACCESS_KEY=lodb
MINIO_SECRET_KEY=
###< app/minio ###

###> app/admin ###
# Admin panel credentials. ADMIN_PASSWORD is a secret: provided via real env (see header).
ADMIN_LOGIN=admin
ADMIN_PASSWORD=
###< app/admin ###

###> app/analytics ###
# Absolute path to a MaxMind/DB-IP GeoLite2-Country .mmdb for audience geo. Empty
# falls back to var/geoip/GeoLite2-Country.mmdb; absent -> geo degrades to unknown.
# See docs/analytics.md for provisioning.
GEOIP_DB_PATH=
###< app/analytics ###

###> doctrine/doctrine-bundle ###
# User data (accounts, favourites, builds). Dev default matches the compose
# postgres service defaults; prod/staging inject DATABASE_URL as real env.
DATABASE_URL="postgresql://lodb:lodb@postgres:5432/lodb?serverVersion=17&charset=utf8"
###< doctrine/doctrine-bundle ###

###> stripe ###
# sk_test_... — see docs/github-actions-secrets.md
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
###< stripe ###
