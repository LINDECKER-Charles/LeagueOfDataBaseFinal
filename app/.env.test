# Test env defaults (committed, NON-secret). APP_ENV=test is forced by phpunit.dist.xml.
#
# Secret test values (APP_SECRET, MINIO_*, ADMIN_PASSWORD) come from app/.env.test.local
# (git-ignored). In CI that file is written from the ENV_TEST GitHub secret; locally,
# create it yourself. See docs/github-actions-secrets.md.

KERNEL_CLASS='App\Kernel'
APP_SECRET=

# Admin panel credentials used by the functional tests (App\Security\AdminAuthenticator).
ADMIN_LOGIN=admin
ADMIN_PASSWORD=
