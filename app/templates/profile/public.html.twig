{% extends 'base.html.twig' %}

{% block title %}{{ profileUser.displayName }} · {{ 'base.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'profile.public.description'|trans({'%username%': profileUser.displayName}) }}{% endblock %}
{% block og_type %}profile{% endblock %}

{% block body %}
<main class="relative px-6 py-12">
    {% include 'partials/main/gradient.html.twig' %}

    <div class="relative mx-auto w-full max-w-2xl">
        <article class="profile-card hextech-frame hx-corners">
            <header class="profile-card__banner">
                <p class="eyebrow">{{ 'profile.public.eyebrow'|trans }}</p>
                <h1 class="mt-2 flex flex-wrap items-center justify-center gap-2.5 font-beaufort text-3xl font-bold uppercase tracking-wide text-gold-grad sm:text-4xl">
                    {{ profileUser.displayName }}
                    {% if profileUser.isSupporter %}{% include 'components/_supporter_badge.html.twig' %}{% endif %}
                </h1>
                <hr class="hx-rule mt-6">
            </header>

            <div class="profile-card__plates">
                <div class="hx-plate">
                    <span class="hx-plate__label">{{ 'profile.identity.member_since'|trans }}</span>
                    <span class="hx-plate__value">{{ memberSince }}</span>
                </div>
                <div class="hx-plate">
                    <span class="hx-plate__label">{{ 'profile.public.builds_count'|trans }}</span>
                    <span class="hx-plate__value">{{ builds|length }}</span>
                </div>
            </div>

            <section aria-label="{{ 'profile.favorites.title'|trans }}">
                <div class="codex-header mb-4">
                    <h2>{{ 'profile.favorites.title'|trans }}</h2>
                </div>
                <div class="profile-card__medallions">
                    {% for def in [
                        { type: 'champion', label: 'profile.slot.champion'|trans },
                        { type: 'item', label: 'profile.slot.item'|trans },
                        { type: 'rune', label: 'profile.slot.rune'|trans },
                        { type: 'summoner', label: 'profile.slot.summoner'|trans },
                    ] %}
                        {% include 'profile/_favorite_socket.html.twig' with {
                            type_label: def.label,
                            favorite: favorites[def.type],
                            compact: true,
                        } only %}
                    {% endfor %}
                </div>
            </section>

            <section aria-label="{{ 'profile.public.builds_title'|trans }}">
                <div class="codex-header mb-4 mt-8">
                    <h2>{{ 'profile.public.builds_title'|trans }}</h2>
                </div>
                {% if builds is empty %}
                    <p class="py-4 text-center font-mono text-sm text-text-muted">{{ 'profile.public.no_builds'|trans }}</p>
                {% else %}
                    <ul class="profile-card__builds">
                        {% for build in builds %}
                            <li>
                                <a class="profile-build" href="{{ path('app_build_show', { token: build.shareToken }) }}">
                                    {% if build.championImage %}
                                        <picture class="profile-build__portrait">
                                            {% if build.championImage ends with '.png' %}
                                                <source srcset="{{ build.championImage|replace({'.png': '.webp'}) }}" type="image/webp">
                                            {% endif %}
                                            <img src="{{ build.championImage }}" alt="{{ build.championName ?? build.championId }}"
                                                 width="48" height="48" loading="lazy" decoding="async">
                                        </picture>
                                    {% else %}
                                        <span class="profile-build__portrait profile-build__portrait--initials" aria-hidden="true">
                                            {{ (build.championName ?? build.championId)|slice(0, 2)|upper }}
                                        </span>
                                    {% endif %}
                                    <span class="min-w-0">
                                        <span class="profile-build__name">{{ build.name }}</span>
                                        <span class="profile-build__meta">
                                            {{ build.championName ?? build.championId }} · {{ build.gameVersion }}
                                        </span>
                                    </span>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>
        </article>
    </div>
</main>
{% endblock %}
