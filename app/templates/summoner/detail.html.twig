{# templates/summoner/detail.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ seo_title('summoner.detail.title'|trans({'%name%': summoner.name ?? 'Summoner Spell'}, 'seo')) }}{% endblock %}
{% block meta_description %}{{ 'summoner.detail.description'|trans({
  '%name%': summoner.name ?? 'Summoner Spell',
  '%version%': version|default(client.session.version ?? (client.versions|first))
}, 'seo') }}{% endblock %}
{% block img %}/preview/summoners.png{% endblock %}

{% block structured_data %}
  {{ seo_jsonld(seo_breadcrumbs([
    { name: 'header.navigation.home'|trans, url: seo_absolute(path('app_home')) },
    { name: 'header.navigation.summoner'|trans, url: seo_absolute(path('app_summoners')) },
    { name: summoner.name ?? '', url: seo_canonical() }
  ])) }}
  {{ seo_jsonld(seo_game_item(
    summoner.name ?? '',
    image is defined and image ? seo_absolute('/' ~ image) : null,
    summoner.description|default('')|striptags
  )) }}
{% endblock %}

{% block body %}
{% set selectedVersion = version|default(client.session.version ?? (client.versions|default([])|first)) %}
{% set selectedLocale  = lang|default(client.session.locale ?? client.currentLocale ?? 'en_US') %}

{# ---- Normalised, meaningful values only (no -1 / No Cost / WIP noise) ------ #}
{% set cd        = summoner.cooldown|default([])|first %}
{% set rng       = summoner.range|default([])|first %}
{% set ammo      = (summoner.maxammo|default(-1)) + 0 %}
{% set costVal   = summoner.cost|default([])|first %}
{% set costType  = summoner.costType|default(summoner.resource|default('')) %}
{% set noCost    = costType is empty or costType|lower in ['no cost', 'nocost'] or costVal in [0, null] %}
{% set modeLabels = {
  'CLASSIC': 'Classic', 'ARAM': 'ARAM', 'CHERRY': 'Arena', 'BRAWL': 'Brawl',
  'NEXUSBLITZ': 'Nexus Blitz', 'URF': 'URF', 'ONEFORALL': 'One for All',
  'SWIFTPLAY': 'Swiftplay', 'ULTBOOK': 'Ultimate Spellbook',
  'PRACTICETOOL': 'Practice Tool', 'TUTORIAL': 'Tutorial'
} %}
{# Curated whitelist: DDragon lists internal/test modes (WIPMODEWIP, RUBY_TRIAL…)
   alongside real queues — only named modes are displayed. #}
{% set modes = summoner.modes|default([])|filter(m => modeLabels[m] is defined) %}

<main class="relative overflow-x-clip px-6 py-14">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-3xl">

    {# ================= Hero : the invocation seal ========================== #}
    <header class="detail-hero mb-12 flex flex-col items-center text-center">
      {% if image %}
        <img class="detail-hero__echo" src="/{{ image }}" alt="" aria-hidden="true" style="right: 50%; translate: 50% -50%; top: 8rem;">
      {% endif %}

      <p class="eyebrow relative mb-7">
        {{ 'summoner.list.title'|trans }}
        <span class="mx-2 text-gold-deep" aria-hidden="true">◆</span>
        <span class="normal-case tracking-normal font-mono text-[11px] text-text-muted">{{ selectedVersion }} · {{ selectedLocale }}</span>
      </p>

      <div class="seal">
        <div class="seal__icon">
          {% if image %}
            <img src="/{{ image }}" alt="{{ summoner.name ?? 'Summoner spell' }}">
          {% else %}
            <span class="grid h-full w-full place-items-center font-beaufort text-2xl text-gold/70">
              {{ (summoner.name ?? '??')|slice(0, 2)|upper }}
            </span>
          {% endif %}
        </div>
      </div>

      <h1 class="hero-name text-gold-grad relative mt-8">{{ summoner.name ?? 'Summoner' }}</h1>

      {# The defining metric of a summoner spell: its cooldown. #}
      {% if cd is not null %}
        <p class="relative mt-4 flex items-baseline gap-2">
          <span class="font-beaufort text-4xl leading-none text-hex-bright">{{ cd }}<span class="text-xl">s</span></span>
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-text-muted">{{ 'summoner.detail.fields.cooldown'|trans }}</span>
        </p>
      {% endif %}
    </header>

    {# ================= Engraved plaques : significant data only ============ #}
    {% set plaques = [] %}
    {% if rng is not null %}
      {% set plaques = plaques|merge([{
        label: 'summoner.detail.fields.range'|trans,
        value: rng >= 25000 ? 'summoner.detail.range_global'|trans : rng
      }]) %}
    {% endif %}
    {% if summoner.summonerLevel is defined and summoner.summonerLevel %}
      {% set plaques = plaques|merge([{
        label: 'summoner.detail.fields.summoner_level'|trans,
        value: 'summoner.detail.unlocked_at'|trans({ '%level%': summoner.summonerLevel })
      }]) %}
    {% endif %}
    {% if not noCost %}
      {% set plaques = plaques|merge([{
        label: 'summoner.detail.fields.cost'|trans,
        value: costType ? costVal ~ ' ' ~ costType : costVal
      }]) %}
    {% endif %}
    {% if ammo > 0 %}
      {% set plaques = plaques|merge([{ label: 'summoner.detail.fields.maxammo'|trans, value: ammo }]) %}
    {% endif %}

    {% if plaques is not empty %}
      <section class="mb-12 grid grid-cols-1 gap-2.5 sm:grid-cols-2" data-reveal>
        {% for p in plaques %}
          <div class="hx-plate">
            <span class="hx-plate__label">{{ p.label }}</span>
            <span class="hx-plate__value">{{ p.value }}</span>
          </div>
        {% endfor %}
      </section>
    {% endif %}

    {# ================= Description ========================================= #}
    {% if summoner.description is defined and summoner.description %}
      <section class="mb-12" data-reveal>
        {% include 'components/codex_header.html.twig' with { title: 'summoner.detail.description'|trans } %}
        <div class="hextech-frame hx-corners p-7">
          <div class="ddragon-rich max-w-[60ch]">{{ summoner.description|ddragon_text|raw }}</div>
        </div>
      </section>
    {% endif %}

    {# ================= Game modes ========================================== #}
    {% if modes is not empty %}
      <section data-reveal>
        {% include 'components/codex_header.html.twig' with {
          title: 'summoner.detail.modes'|trans,
          meta: modes|length
        } %}
        <div class="flex flex-wrap gap-2">
          {% for m in modes %}
            <span class="hx-chip">{{ modeLabels[m]|default(m|lower|capitalize) }}</span>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% include 'components/detail_pager.html.twig' with {
      nav: nav|default({ prev: null, next: null }),
      route: 'app_summoner',
      list_href: path('app_summoners', { version: selectedVersion, lang: selectedLocale }),
      version: selectedVersion,
      lang: selectedLocale
    } %}
    {% include 'components/detail_actions.html.twig' %}
  </div>
</main>
{% endblock %}
