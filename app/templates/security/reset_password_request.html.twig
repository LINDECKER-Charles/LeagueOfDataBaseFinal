{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.reset.request_title'|trans }} · {{ 'base.title'|trans }}{% endblock %}
{% block meta_robots %}noindex, nofollow{% endblock %}

{% block body %}
<main class="auth-portal">
    <section class="auth-card hextech-frame hx-corners relative w-full max-w-md p-8 sm:p-10">
        <p class="eyebrow">{{ 'auth.eyebrow'|trans }}</p>
        <h1 class="mt-2 font-beaufort text-3xl font-bold uppercase tracking-wide text-gold-grad">
            {{ 'auth.reset.request_title'|trans }}
        </h1>
        <hr class="hx-rule mt-5">
        <p class="mt-6 text-sm text-text-muted">{{ 'auth.reset.request_lede'|trans }}</p>

        {{ form_start(requestForm, {attr: {'data-turbo': 'false', class: 'mt-6 space-y-5'}}) }}
            <div>
                <label for="{{ requestForm.email.vars.id }}" class="auth-label">{{ 'auth.reset.email'|trans }}</label>
                {{ form_widget(requestForm.email, {attr: {class: 'hx-input mt-1.5', autofocus: true}}) }}
                {% for err in requestForm.email.vars.errors %}
                    <p class="auth-field-error">{{ err.message }}</p>
                {% endfor %}
            </div>
            <button type="submit" class="hx-btn w-full">{{ 'auth.reset.submit_request'|trans }}</button>
        {{ form_end(requestForm) }}

        <div class="gold-hairline mt-8 pt-5 text-center text-sm text-text-muted">
            <a href="{{ path('app_login') }}" class="nav-link text-gold">{{ 'auth.reset.back_to_login'|trans }}</a>
        </div>
    </section>
</main>
{% endblock %}
