{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.reset.check_email_title'|trans }} · {{ 'base.title'|trans }}{% endblock %}
{% block meta_robots %}noindex, nofollow{% endblock %}

{% block body %}
<main class="auth-portal">
    <section class="auth-card hextech-frame hx-corners relative w-full max-w-md p-8 sm:p-10 text-center">
        <p class="eyebrow">{{ 'auth.eyebrow'|trans }}</p>
        <h1 class="mt-2 font-beaufort text-3xl font-bold uppercase tracking-wide text-gold-grad">
            {{ 'auth.reset.check_email_title'|trans }}
        </h1>
        <hr class="hx-rule mt-5">
        <p class="mt-6 text-sm text-text-muted">{{ 'auth.reset.check_email_lede'|trans }}</p>

        <div class="gold-hairline mt-8 pt-5 text-sm text-text-muted">
            <a href="{{ path('app_login') }}" class="nav-link text-gold">{{ 'auth.reset.back_to_login'|trans }}</a>
        </div>
    </section>
</main>
{% endblock %}
