{# Password + confirmation + reactive CNIL checklist for a RepeatedType field
   (used by registration and the profile set-password panel). RepeatedType
   quirk: the mismatch error and mapped constraint violations land on the FIRST
   child, so each child renders its own errors plus the compound's. #}
<div>
    <label for="{{ field.first.vars.id }}" class="auth-label">{{ 'auth.register.password'|trans }}</label>
    {{ form_widget(field.first, {attr: {class: 'hx-input mt-1.5'}}) }}
    {% for err in field.first.vars.errors %}
        <p class="auth-field-error">{{ err.message }}</p>
    {% endfor %}
</div>
<div>
    <label for="{{ field.second.vars.id }}" class="auth-label">{{ 'auth.register.password_confirm'|trans }}</label>
    {{ form_widget(field.second, {attr: {class: 'hx-input mt-1.5'}}) }}
    {% for err in field.second.vars.errors %}
        <p class="auth-field-error">{{ err.message }}</p>
    {% endfor %}
    {% for err in field.vars.errors %}
        <p class="auth-field-error">{{ err.message }}</p>
    {% endfor %}
</div>
{% include 'security/_password_checklist.html.twig' with {
    passwordId: field.first.vars.id,
    confirmId: field.second.vars.id,
} only %}
