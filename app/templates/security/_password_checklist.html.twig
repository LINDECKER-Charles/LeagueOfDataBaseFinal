{# Reactive CNIL checklist island, mounted next to the two password inputs it
   observes (register + profile set-password). No-JS fallback: the static help
   line below stays rendered until (unless) the island mounts. #}
<div data-vue="password-checklist" data-props="{{ {
    passwordSelector: '#' ~ passwordId,
    confirmSelector: '#' ~ confirmId,
    labels: {
        length: 'auth.password.rule_length'|trans,
        lowercase: 'auth.password.rule_lowercase'|trans,
        uppercase: 'auth.password.rule_uppercase'|trans,
        digit: 'auth.password.rule_digit'|trans,
        special: 'auth.password.rule_special'|trans,
        match: 'auth.password.rule_match'|trans,
    },
}|json_encode|e('html_attr') }}">
    <p class="auth-help">{{ 'auth.register.password_help'|trans }}</p>
</div>
