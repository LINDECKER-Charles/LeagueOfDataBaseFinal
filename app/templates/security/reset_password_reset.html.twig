{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.reset.reset_title'|trans }} · {{ 'base.title'|trans }}{% endblock %}
{% block meta_robots %}noindex, nofollow{% endblock %}

{% block body %}
<main class="auth-portal">
    <section class="auth-card hextech-frame hx-corners relative w-full max-w-md p-8 sm:p-10">
        <p class="eyebrow">{{ 'auth.eyebrow'|trans }}</p>
        <h1 class="mt-2 font-beaufort text-3xl font-bold uppercase tracking-wide text-gold-grad">
            {{ 'auth.reset.reset_title'|trans }}
        </h1>
        <hr class="hx-rule mt-5">

        {% if resetForm.vars.errors|length > 0 %}
            <div class="auth-error mt-6" role="alert">
                {% for err in resetForm.vars.errors %}<p>{{ err.message }}</p>{% endfor %}
            </div>
        {% endif %}

        {{ form_start(resetForm, {attr: {'data-turbo': 'false', class: 'mt-6 space-y-5'}}) }}
            {% include 'security/_password_pair.html.twig' with { field: resetForm.plainPassword } only %}
            <button type="submit" class="hx-btn w-full">{{ 'auth.reset.submit_reset'|trans }}</button>
        {{ form_end(resetForm) }}
    </section>
</main>
{% endblock %}
