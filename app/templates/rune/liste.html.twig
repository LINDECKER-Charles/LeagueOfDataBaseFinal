{% extends 'base.html.twig' %}

{% block title %}Runes - {{ meta.currentPage }}/{{ meta.nombrePage }}{% endblock %}
{% block meta_description %}
  Découvrez la liste complète des runes de League of Legends ({{ meta.totalItem }} au total),
  organisées par arbre pour le patch {{ client.session.version ?? (client.versions|first) }}.
{% endblock %}
{% block img %}/preview/runes.png{% endblock %}

{% block body %}
<main class="relative px-6 py-12">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-[110rem]">
    <header class="mb-10 flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      {% include 'components/section_header.html.twig' with {
        eyebrow: 'Data Dragon · ' ~ (client.session.version ?? (client.versions|first)),
        title: 'rune.list.title'|trans,
        count: meta.totalItem,
        count_label: 'rune.list.title'|trans|lower
      } %}
      {% include 'components/list_controls.html.twig' with {
        meta: meta,
        per_page: false,
        route: 'app_runes',
        version: client.session.version ?? (client.versions|first),
        lang: client.session.locale ?? client.currentLocale ?? 'en_US'
      } %}
    </header>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {% for runeTree in runesReforgeds %}
        {% embed 'components/entity_card.html.twig' with {
          href: path('app_rune', { name: runeTree.key, version: meta.version, lang: meta.lang }),
          img: images[runeTree.key].icon ?? null,
          name: runeTree.name,
          sub: runeTree.key,
          img_scale: 0.72,
          footer_label: 'common.detail'|trans
        } %}
          {% block card_body %}
            {% set slot0 = runeTree.slots[0].runes ?? [] %}
            {% if slot0 is not empty %}
              <div class="grid grid-cols-4 gap-2 px-4 pb-4">
                {% for r in slot0 %}
                  {% set runeIcon = images[runeTree.key].slots[0][r.key] ?? null %}
                  {% if runeIcon %}
                    <div class="aspect-square overflow-hidden border border-gold-deep/40 bg-void/60">
                      <img src="/{{ runeIcon }}" alt="{{ r.name }}" class="h-full w-full object-cover">
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          {% endblock %}
        {% endembed %}
      {% else %}
        {% include 'components/empty_state.html.twig' %}
      {% endfor %}
    </div>

    {% include 'partials/pagination.html.twig' with { route: 'app_runes' } %}
  </div>
</main>
{% endblock %}
