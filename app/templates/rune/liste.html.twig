{% extends 'base.html.twig' %}

{% block title %}{{ seo_title('rune.list.title'|trans({}, 'seo')) }}{% endblock %}
{% block meta_description %}{{ 'rune.list.description'|trans({'%count%': meta.totalItem, '%version%': meta.version}, 'seo') }}{% endblock %}
{% block img %}/preview/runes.png{% endblock %}

{% block structured_data %}
  {% set seoItems = [] %}
  {% for runeTree in runesReforgeds|slice(0, 20) %}
    {% set seoItems = seoItems|merge([{
      name: runeTree.name|default(runeTree.key),
      url: seo_absolute(resource_path('app_rune', { name: runeTree.key }, meta.version, ''))
    }]) %}
  {% endfor %}
  {{ seo_jsonld(seo_item_list(seoItems)) }}
{% endblock %}

{% block body %}
<main class="relative px-6 py-12">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-[110rem]">
    <header class="mb-8">
      {% include 'components/section_header.html.twig' with {
        eyebrow: 'Data Dragon · ' ~ (client.session.version ?? (client.versions|first)),
        title: 'rune.list.title'|trans,
        count: meta.totalItem,
        count_label: 'rune.list.title'|trans|lower
      } %}
    </header>

    {% include 'components/list_filter.html.twig' with { grid_id: 'rune-grid' } %}

    <div id="rune-grid" class="resource-grid grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {% for runeTree in runesReforgeds %}
        {% embed 'components/entity_card.html.twig' with {
          href: resource_path('app_rune', { name: runeTree.key }, meta.version, meta.lang),
          img: images[runeTree.key].icon ?? null,
          name: runeTree.name,
          sub: runeTree.key,
          img_scale: 0.72,
          footer_label: 'common.detail'|trans,
          filter_text: (runeTree.name ~ ' ' ~ runeTree.key)|lower,
          filter_tags: [runeTree.name]
        } %}
          {% block card_body %}
            {% set slot0 = runeTree.slots[0].runes ?? [] %}
            {% if slot0 is not empty %}
              <div class="grid grid-cols-4 gap-2 px-4 pb-4">
                {% for r in slot0 %}
                  {% set runeIcon = images[runeTree.key].slots[0][r.key] ?? null %}
                  {% if runeIcon %}
                    <div class="aspect-square overflow-hidden border border-gold-deep/40 bg-void/60">
                      <img src="/{{ runeIcon }}" alt="{{ r.name }}" class="h-full w-full object-cover">
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          {% endblock %}
        {% endembed %}
      {% else %}
        {% include 'components/empty_state.html.twig' %}
      {% endfor %}
    </div>
  </div>
</main>
{% endblock %}
