{% extends 'base.html.twig' %}

{# Path → couleur : map indexé par la KEY (stable, non localisée) de l'arbre.
   Les classes .path-* définissent la variable CSS --path exploitée par
   .path-text / .path-border / .path-glow / .path-bar. #}
{% set pathClass = {
  'Precision':   'path-precision',
  'Domination':  'path-domination',
  'Sorcery':     'path-sorcery',
  'Resolve':     'path-resolve',
  'Inspiration': 'path-inspiration'
}[rune.key]|default('path-precision') %}

{% block title %}{{ 'rune.detail.title'|trans({'%name%': rune.name}) }}{% endblock %}
{% block meta_description %}
  {{ 'rune.detail.meta_description'|trans({'%name%': rune.name, '%version%': client.session.version ?? (client.versions|first)}) }}.
{% endblock %}
{% block img %}/{{ images[rune.key].icon ?? '' }}{% endblock %}

{% block body %}
<main class="relative px-6 py-12">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-6xl {{ pathClass }}">

    {# ── Hero : identité couleur de l'arbre ─────────────────────────────── #}
    <header class="mb-12 flex items-center gap-6 sm:gap-8">
      {% set treeIcon = images[rune.key].icon ?? null %}
      {% if treeIcon %}
        <div class="hextech-frame path-glow relative h-24 w-24 shrink-0 overflow-hidden sm:h-28 sm:w-28">
          <img src="/{{ treeIcon }}" alt="{{ rune.name }}"
               class="absolute inset-0 h-full w-full object-contain p-3">
        </div>
      {% else %}
        <div class="hextech-frame path-glow grid h-24 w-24 shrink-0 place-items-center font-beaufort text-2xl path-text sm:h-28 sm:w-28">
          {{ rune.name|slice(0, 2)|upper }}
        </div>
      {% endif %}

      <div class="min-w-0">
        <p class="eyebrow path-text mb-2">{{ 'rune.list.title'|trans }}</p>
        <h1 class="font-beaufort text-4xl uppercase leading-none tracking-wide text-gold-bright sm:text-6xl">{{ rune.name }}</h1>
        <div class="mt-3 h-px w-40 max-w-full path-bar"></div>
        <p class="mt-3 font-mono text-xs uppercase tracking-wider text-text-dim">
          {{ rune.key }} · {{ client.session.version ?? (client.versions|first) }}
        </p>
      </div>
    </header>

    {% if rune.slots is defined and rune.slots|length > 0 %}
      {% set keystoneSlot = rune.slots|first %}

      {# ── Keystones (slots[0]) : mises en scène ──────────────────────────── #}
      <section class="mb-4">
        <h2 class="mb-5 flex items-center gap-3 font-beaufort text-sm uppercase tracking-[0.22em] path-text">
          <span aria-hidden="true" class="h-4 w-1 path-bar"></span>
          {{ 'rune.detail.keystone'|trans }}
        </h2>
        <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
          {% for r in keystoneSlot.runes %}
            {% set runeIcon = images[rune.key].slots[0][r.key] ?? null %}
            <article class="hextech-frame path-border flex flex-col gap-4 p-6">
              <div class="flex items-center gap-4">
                {% if runeIcon %}
                  <div class="h-16 w-16 shrink-0 overflow-hidden border path-border bg-void">
                    <img src="/{{ runeIcon }}" alt="{{ r.name }}" class="h-full w-full object-cover">
                  </div>
                {% endif %}
                <h3 class="font-beaufort text-lg tracking-wide text-gold-bright">{{ r.name }}</h3>
              </div>
              {% if r.longDesc %}
                <div class="ddragon-rich text-sm text-text-muted">{{ r.longDesc|raw }}</div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      </section>

      {# ── Runes mineures (slots[1..]) : denses, shortDesc lisible ─────────── #}
      {% for slotIndex, slot in rune.slots %}
        {% if slotIndex > 0 %}
          <hr class="hx-rule my-10">
          <section>
            <h2 class="mb-5 flex items-center gap-3 font-beaufort text-sm uppercase tracking-[0.22em] path-text">
              <span aria-hidden="true" class="h-4 w-1 path-bar"></span>
              {% if slotIndex == 1 %}{{ 'rune.detail.minor'|trans }}{% endif %}
              <span class="font-mono text-xs tracking-normal text-text-dim">
                {{ 'rune.detail.slot_n'|trans({'%n%': slotIndex}) }}
              </span>
            </h2>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {% for r in slot.runes %}
                {% set runeIcon = images[rune.key].slots[slotIndex][r.key] ?? null %}
                <article class="hextech-frame hextech-frame-hover group flex flex-col p-4">
                  <div class="flex items-center gap-3">
                    {% if runeIcon %}
                      <div class="h-10 w-10 shrink-0 overflow-hidden border border-gold-deep/40 bg-void">
                        <img src="/{{ runeIcon }}" alt="{{ r.name }}" class="h-full w-full object-cover">
                      </div>
                    {% endif %}
                    <h3 class="min-w-0 truncate font-beaufort text-sm tracking-wide text-text">{{ r.name }}</h3>
                  </div>

                  {% set summary = r.shortDesc|default(r.longDesc)|default('') %}
                  {% if summary %}
                    <div class="ddragon-rich mt-3 text-xs leading-snug text-text-muted">{{ summary|raw }}</div>
                  {% endif %}

                  {% if r.longDesc and r.shortDesc is defined and r.shortDesc and r.longDesc != r.shortDesc %}
                    <details class="mt-3 border-t border-gold-deep/25 pt-3">
                      <summary class="cursor-pointer select-none font-mono text-[11px] uppercase tracking-wider text-text-dim transition-colors hover:text-gold-light">
                        {{ r.key }}
                      </summary>
                      <div class="ddragon-rich mt-2 text-xs leading-snug text-text-muted">{{ r.longDesc|raw }}</div>
                    </details>
                  {% endif %}
                </article>
              {% endfor %}
            </div>
          </section>
        {% endif %}
      {% endfor %}
    {% else %}
      {% include 'components/empty_state.html.twig' %}
    {% endif %}

    {% include 'components/detail_actions.html.twig' with { back_href: path('app_runes'), back_label: 'common.back'|trans } %}
  </div>
</main>
{% endblock %}
