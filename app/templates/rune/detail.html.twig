{% extends 'base.html.twig' %}

{% block title %}{{ 'rune.detail.title'|trans({'%name%': rune.name}) }}{% endblock %}
{% block meta_description %}
  {{ 'rune.detail.meta_description'|trans({'%name%': rune.name, '%version%': client.session.version ?? (client.versions|first)}) }}.
{% endblock %}
{% block img %}/{{ images[rune.name].icon ?? '' }}{% endblock %}

{% block body %}
<main class="relative px-6 py-12">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-6xl">
    {% include 'components/detail_hero.html.twig' with {
      img: images[rune.key].icon ?? null,
      img_scale: 0.72,
      name: rune.name,
      sub: rune.key,
      eyebrow: 'rune.list.title'|trans
    } %}

    {# Tree summary #}
    <section class="mb-10 hextech-frame p-6">
      <h2 class="mb-3 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">{{ 'rune.detail.title'|trans({'%name%': rune.name}) }}</h2>
      {% if rune.slots is defined and rune.slots|length > 0 %}
        <p class="leading-relaxed text-text-muted">{{ rune.slots[0].runes[0].longDesc|default('')|raw }}</p>
      {% else %}
        <p class="italic text-text-muted">{{ 'rune.detail.no_description'|trans }}</p>
      {% endif %}
    </section>

    {# Slots #}
    {% if rune.slots is defined and rune.slots|length > 0 %}
      {% for slotIndex, slot in rune.slots %}
        <section class="mb-10">
          <h3 class="mb-4 flex items-center gap-3 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">
            <span class="font-mono text-hex">{{ '%02d'|format(slotIndex + 1) }}</span>
            {{ 'rune.slot'|trans }}
          </h3>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {% for r in slot.runes %}
              {% set runeIcon = images[rune.key].slots[slotIndex][r.key] ?? null %}
              <div class="hextech-frame hextech-frame-hover group flex flex-col overflow-hidden">
                <div class="flex items-center gap-3 p-4">
                  {% if runeIcon %}
                    <div class="h-12 w-12 shrink-0 overflow-hidden border border-gold-deep/40 bg-void">
                      <img src="/{{ runeIcon }}" alt="{{ r.name }}" class="h-full w-full object-cover">
                    </div>
                  {% endif %}
                  <div class="min-w-0">
                    <h4 class="truncate font-beaufort text-sm tracking-wide text-text">{{ r.name }}</h4>
                    <p class="truncate font-mono text-xs text-text-muted">{{ r.key }}</p>
                  </div>
                </div>
                {% if r.longDesc %}
                  <div class="border-t border-gold-deep/25 px-4 py-3 text-xs leading-snug text-text-muted">{{ r.longDesc|raw }}</div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        </section>
      {% endfor %}
    {% else %}
      {% include 'components/empty_state.html.twig' %}
    {% endif %}

    {% include 'components/detail_actions.html.twig' with { back_href: path('app_runes'), back_label: 'common.back'|trans } %}
  </div>
</main>
{% endblock %}
