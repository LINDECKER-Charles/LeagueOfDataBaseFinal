{% extends 'base.html.twig' %}

{# Path → couleur : map indexé par la KEY (stable, non localisée) de l'arbre.
   Les classes .path-* définissent la variable CSS --path exploitée par
   .path-text / .path-border / .path-glow / .path-bar / .path-ambient. #}
{% set pathClass = {
  'Precision':   'path-precision',
  'Domination':  'path-domination',
  'Sorcery':     'path-sorcery',
  'Resolve':     'path-resolve',
  'Inspiration': 'path-inspiration'
}[rune.key]|default('path-precision') %}

{% block title %}{{ seo_title('rune.detail.title'|trans({'%name%': rune.name}, 'seo')) }}{% endblock %}
{% block meta_description %}{{ 'rune.detail.description'|trans({
  '%name%': rune.name,
  '%version%': version|default(client.session.version ?? (client.versions|first))
}, 'seo') }}{% endblock %}
{% block img %}/{{ images[rune.key].icon ?? '' }}{% endblock %}

{% block structured_data %}
  {{ seo_jsonld(seo_breadcrumbs([
    { name: 'header.navigation.home'|trans, url: seo_absolute(path('app_home')) },
    { name: 'header.navigation.runes'|trans, url: seo_absolute(resource_path('app_runes', {}, version|default(''), '')) },
    { name: rune.name ?? '', url: seo_canonical() }
  ])) }}
  {{ seo_jsonld(seo_game_item(
    rune.name ?? '',
    images[rune.key].icon is defined and images[rune.key].icon ? seo_absolute('/' ~ images[rune.key].icon) : null,
    null
  )) }}
{% endblock %}

{% block body %}
{% set selectedVersion = version|default(client.session.version ?? (client.versions|default([])|first)) %}
{% set selectedLocale  = lang|default(client.session.locale ?? client.currentLocale ?? 'en_US') %}

<main class="relative px-6 py-14 {{ pathClass }}">
  {% include 'partials/main/gradient.html.twig' %}
  {# Path-tinted ambience over the shared backdrop. #}
  <div aria-hidden="true" class="path-ambient pointer-events-none absolute inset-0"></div>

  <div class="relative mx-auto max-w-6xl">

    {# ================= Hero : the path's identity ========================== #}
    <header class="detail-hero mb-14 flex flex-col gap-8 sm:flex-row sm:items-center">
      {% set treeIcon = images[rune.key].icon ?? null %}
      <div class="keystone__icon path-glow" style="width: 7.5rem;">
        {% if treeIcon %}
          <img src="/{{ treeIcon }}" alt="" class="p-5">
        {% else %}
          <span class="grid h-full w-full place-items-center font-beaufort text-2xl path-text">{{ rune.name|slice(0, 2)|upper }}</span>
        {% endif %}
      </div>

      <div class="min-w-0">
        <p class="eyebrow path-text mb-2.5">
          {{ 'rune.list.title'|trans }}
          <span class="mx-2 opacity-60" aria-hidden="true">◆</span>
          <span class="normal-case tracking-normal font-mono text-[11px] text-text-muted">{{ selectedVersion }} · {{ selectedLocale }}</span>
        </p>
        <h1 class="hero-name path-text" style="text-shadow: 0 0 34px color-mix(in srgb, var(--path) 45%, transparent);">
          {{ rune.name }}
        </h1>
        <div class="mt-4 h-px w-48 max-w-full path-bar"></div>
      </div>
    </header>

    {# ================= Signature : the constellation ======================= #}
    {% if rune.slots is defined and rune.slots|length > 0 %}
      <div class="constellation">

        {# ---- Keystones (slots[0]) ---------------------------------------- #}
        {% set keystoneSlot = rune.slots|first %}
        <section data-reveal>
          <div class="slot-node">
            <span><i aria-hidden="true"></i>{{ 'rune.detail.keystone'|trans }}<i aria-hidden="true"></i></span>
          </div>
          <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
            {% for r in keystoneSlot.runes %}
              {% set runeIcon = images[rune.key].slots[0][r.key] ?? null %}
              <article class="hextech-frame path-border flex gap-5 p-6">
                <div class="keystone__icon">
                  {% if runeIcon %}<img src="/{{ runeIcon }}" alt="">{% endif %}
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="mb-3 font-beaufort text-lg uppercase tracking-wide text-gold-bright">{{ r.name }}</h3>
                  {% if r.longDesc|default('') %}
                    <div class="ddragon-rich text-sm text-text-muted">{{ r.longDesc|ddragon_text|raw }}</div>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
          </div>
        </section>

        {# ---- Minor slots (1..3) strung on the spine ----------------------- #}
        {% for slotIndex, slot in rune.slots %}
          {% if slotIndex > 0 %}
            <section data-reveal>
              <div class="slot-node">
                <span>
                  <i aria-hidden="true"></i>
                  {{ 'rune.detail.slot_n'|trans({'%n%': slotIndex}) }}
                  <i aria-hidden="true"></i>
                </span>
              </div>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {% for r in slot.runes %}
                  {% set runeIcon = images[rune.key].slots[slotIndex][r.key] ?? null %}
                  <article class="hextech-frame hextech-frame-hover group flex flex-col p-5">
                    <div class="flex items-center gap-3.5">
                      <div class="rune-medallion">
                        {% if runeIcon %}<img src="/{{ runeIcon }}" alt="">{% endif %}
                      </div>
                      <h3 class="min-w-0 font-beaufort text-[15px] leading-snug tracking-wide text-text">{{ r.name }}</h3>
                    </div>

                    {% set summary = r.shortDesc|default(r.longDesc)|default('') %}
                    {% if summary %}
                      <div class="ddragon-rich mt-3.5 text-xs leading-snug text-text-muted">{{ summary|ddragon_text|raw }}</div>
                    {% endif %}

                    {% if r.longDesc|default('') and r.shortDesc|default('') and r.longDesc != r.shortDesc %}
                      <details class="mt-3.5 border-t border-gold-deep/25 pt-3">
                        <summary class="cursor-pointer select-none font-mono text-[11px] uppercase tracking-wider text-text-dim transition-colors hover:text-gold-light">
                          {{ 'rune.detail.full_description'|trans }}
                        </summary>
                        <div class="ddragon-rich mt-2 text-xs leading-snug text-text-muted">{{ r.longDesc|ddragon_text|raw }}</div>
                      </details>
                    {% endif %}
                  </article>
                {% endfor %}
              </div>
            </section>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      {% include 'components/empty_state.html.twig' %}
    {% endif %}

    {% include 'components/detail_pager.html.twig' with {
      nav: nav|default({ prev: null, next: null }),
      route: 'app_rune',
      list_href: resource_path('app_runes', {}, selectedVersion, selectedLocale),
      version: selectedVersion,
      lang: selectedLocale
    } %}
    {% include 'components/detail_actions.html.twig' %}
  </div>
</main>
{% endblock %}
