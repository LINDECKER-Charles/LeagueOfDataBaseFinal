{% extends 'email/_base.html.twig' %}

{% set duration = expiresAtMessageKey|trans(expiresAtMessageData, 'ResetPasswordBundle') %}

{% block title %}{{ 'email.reset.subject'|trans }}{% endblock %}
{% block preheader %}{{ 'email.reset.preheader'|trans }}{% endblock %}
{% block heading %}{{ 'email.reset.heading'|trans }}{% endblock %}
{% block lede %}{{ 'email.reset.lede'|trans }}{% endblock %}
{% block cta_url %}{{ actionUrl }}{% endblock %}
{% block cta_label %}{{ 'email.reset.cta'|trans }}{% endblock %}
{% block note %}{{ 'email.reset.expiry'|trans({ '%duration%': duration }) }}{% endblock %}
{% block footer_reason %}{{ 'email.reset.footer_reason'|trans }}{% endblock %}
