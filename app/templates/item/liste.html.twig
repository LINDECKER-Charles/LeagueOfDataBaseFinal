{# templates/item/liste.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Objects - {{ client.session.version ?? (client.versions|first) }}{% endblock %}
{% block meta_description %}
  {{ 'item.list.meta_description'|trans({ '%version%': client.session.version ?? (client.versions|first) }) }}
{% endblock %}
{% block img %}/preview/objects.png{% endblock %}

{% block body %}
<main class="relative px-6 py-12">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-[110rem]">
    <header class="mb-8">
      {% include 'components/section_header.html.twig' with {
        eyebrow: 'Data Dragon · ' ~ (client.session.version ?? (client.versions|first)),
        title: 'item.list.header'|trans,
        count: meta.totalItem,
        count_label: 'item.list.title'|trans|lower
      } %}
    </header>

    {% include 'components/list_filter.html.twig' with { grid_id: 'item-grid' } %}

    <div id="item-grid" class="resource-grid grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {% for id, item in items %}
        {% set desc = item.plaintext is not empty ? item.plaintext : (item.description|default('')) %}
        {% embed 'components/entity_card.html.twig' with {
          href: path('app_item', { name: id, version: meta.version, lang: meta.lang }),
          img: images[item.name]|default(null),
          name: item.name|default(''),
          sub: id,
          img_fit: 'contain',
          filter_text: (item.name|default('') ~ ' ' ~ id)|lower,
          filter_tags: item.tags is defined and item.tags is iterable ? item.tags : []
        } %}
          {% block card_body %}
            <div class="px-4 pb-3">
              <div class="grid grid-cols-2 gap-2">
                <div class="stat-cell">
                  <div class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{{ 'item.list.cost_total'|trans }}</div>
                  <div class="mt-0.5 font-beaufort text-gold">{{ item.gold.total|default(0) }}</div>
                </div>
                <div class="stat-cell">
                  <div class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{{ 'item.list.cost_sell'|trans }}</div>
                  <div class="mt-0.5 font-beaufort text-text">{{ item.gold.sell|default(0) }}</div>
                </div>
              </div>
            </div>

            {% set tags = item.tags is defined and item.tags is iterable ? item.tags : [] %}
            {% set intoItems = item.into is defined and item.into is iterable ? item.into : [] %}
            {% if tags is not empty or intoItems is not empty or desc %}
              <div class="mt-auto">
                {% if tags is not empty %}
                  <details class="group/acc border-t border-gold-deep/30">
                    <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-2.5 font-mono text-[11px] uppercase tracking-wider text-text-muted hover:text-hex">
                      <span>{{ 'item.list.categories'|trans }}</span>
                      <svg class="h-3.5 w-3.5 transition-transform group-open/acc:rotate-180" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/></svg>
                    </summary>
                    <div class="flex flex-wrap gap-1.5 px-4 pb-4">
                      {% for t in tags %}<span class="hx-chip">{{ t }}</span>{% endfor %}
                    </div>
                  </details>
                {% endif %}
                {% if intoItems is not empty %}
                  <details class="group/acc border-t border-gold-deep/30">
                    <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-2.5 font-mono text-[11px] uppercase tracking-wider text-text-muted hover:text-hex">
                      <span>{{ 'item.list.evolutions'|trans }}</span>
                      <svg class="h-3.5 w-3.5 transition-transform group-open/acc:rotate-180" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/></svg>
                    </summary>
                    <div class="flex flex-wrap gap-2 px-4 pb-4">
                      {% for iid in intoItems %}
                        {% set child = related[iid]|default(null) %}
                        <a href="{{ path('app_item', { name: iid, version: meta.version, lang: meta.lang }) }}"
                           class="group/evo flex items-center gap-1.5 rounded border border-gold-deep/40 bg-void/60 px-1.5 py-1 transition-colors hover:border-gold hover:bg-void/90"
                           title="{{ child.name|default(iid) }}">
                          {% if child and child.image %}<img src="/{{ child.image }}" alt="{{ child.name }}" width="24" height="24" loading="lazy" decoding="async" class="h-6 w-6 object-contain">{% endif %}
                          <span class="font-mono text-xs text-text-muted group-hover/evo:text-hex">{{ child.name|default(iid) }}</span>
                        </a>
                      {% endfor %}
                    </div>
                  </details>
                {% endif %}
                {% if desc %}
                  <details class="group/acc border-t border-gold-deep/30">
                    <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-2.5 font-mono text-[11px] uppercase tracking-wider text-text-muted hover:text-hex">
                      <span>{{ 'item.list.description'|trans }}</span>
                      <svg class="h-3.5 w-3.5 transition-transform group-open/acc:rotate-180" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd"/></svg>
                    </summary>
                    <div class="px-4 pb-4 text-[13px] leading-snug text-text-muted">{{ desc|raw }}</div>
                  </details>
                {% endif %}
              </div>
            {% endif %}
          {% endblock %}
        {% endembed %}
      {% else %}
        {% include 'components/empty_state.html.twig' %}
      {% endfor %}
    </div>
  </div>
</main>
{% endblock %}
