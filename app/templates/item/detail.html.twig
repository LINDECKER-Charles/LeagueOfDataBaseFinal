{% extends 'base.html.twig' %}

{% block title %}{{ item.name ?? 'Item' }} - {{ client.session.version ?? (client.versions|first) }}{% endblock %}
{% block meta_description %}
  {{ 'item.detail.meta_description'|trans({
    '%name%': item.name ?? 'Item',
    '%version%': client.session.version ?? (client.versions|first)
  }) }}
{% endblock %}
{% block img %}/preview/objects.png{% endblock %}

{% block body %}
{% set selectedVersion = client.session.version ?? (client.versions|default([])|first) %}
{% set selectedLocale  = client.session.locale  ?? client.currentLocale ?? 'en_US' %}

<main class="relative px-6 py-12">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-5xl">
    {% include 'components/detail_hero.html.twig' with {
      img: image,
      img_fit: 'contain',
      name: item.name ?? 'Item',
      sub: item.plaintext ?? '',
      eyebrow: 'item.list.title'|trans,
      meta_line: 'item.detail.version_locale'|trans({ '%version%': selectedVersion, '%locale%': selectedLocale })
    } %}

    {# Prices #}
    <section class="mb-10 grid grid-cols-3 gap-2">
      <div class="stat-cell">
        <div class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{{ 'item.detail.price_total'|trans }}</div>
        <div class="mt-0.5 font-beaufort text-gold">{{ item.gold.total ?? '–' }}</div>
      </div>
      <div class="stat-cell">
        <div class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{{ 'item.detail.price_base'|trans }}</div>
        <div class="mt-0.5 font-beaufort text-text">{{ item.gold.base ?? '–' }}</div>
      </div>
      <div class="stat-cell">
        <div class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{{ 'item.detail.price_sell'|trans }}</div>
        <div class="mt-0.5 font-beaufort text-text">{{ item.gold.sell ?? '–' }}</div>
      </div>
    </section>

    {# Categories #}
    {% if item.tags is defined and item.tags is iterable and item.tags is not empty %}
      <section class="mb-10">
        <h2 class="mb-4 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">{{ 'item.detail.categories'|trans }}</h2>
        <div class="flex flex-wrap gap-2">
          {% for tag in item.tags %}<span class="hx-chip">{{ tag }}</span>{% endfor %}
        </div>
      </section>
    {% endif %}

    {# Builds into #}
    {% if item.into is defined and item.into is iterable and item.into is not empty %}
      <section class="mb-10">
        <h2 class="mb-4 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">{{ 'item.detail.evolutions'|trans }}</h2>
        <div class="flex flex-wrap gap-3">
          {% for child in item.into %}
            {% set childImg = images[child]|default(null) %}
            <div class="flex items-center gap-2 stat-cell">
              {% if childImg %}<img src="/{{ childImg }}" alt="Item {{ child }}" class="h-8 w-8 object-contain">{% endif %}
              <span class="font-mono text-sm text-text-muted">{{ child }}</span>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# Stats #}
    {% if item.stats is defined and item.stats is not empty %}
      <section class="mb-10">
        <h2 class="mb-4 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">{{ 'item.detail.stats'|trans }}</h2>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
          {% for key, val in item.stats %}
            <div class="stat-cell flex items-baseline justify-between">
              <span class="font-mono text-[11px] text-text-muted">{{ key }}</span>
              <span class="font-beaufort text-text">{{ val }}</span>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# Description #}
    {% if item.description is defined and item.description %}
      <section class="mb-4">
        <h2 class="mb-4 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">{{ 'item.detail.description'|trans }}</h2>
        <div class="hextech-frame p-6 leading-relaxed text-text">{{ item.description|raw }}</div>
      </section>
    {% endif %}

    {% include 'components/detail_actions.html.twig' with { back_href: path('app_items') } %}
  </div>
</main>
{% endblock %}
