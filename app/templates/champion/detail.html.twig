{# templates/champion/detail.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ champion.name ?? 'Champion' }} - {{ client.session.version ?? (client.versions|first) }}{% endblock %}
{% block meta_description %}
  {{ 'champion.detail.meta_description'|trans({
    '%name%': champion.name ?? 'Champion',
    '%version%': client.session.version ?? (client.versions|first)
  }) }}
{% endblock %}
{% block img %}/preview/champions.png{% endblock %}

{% block body %}
{% set selectedVersion = client.session.version ?? (client.versions|default([])|first) %}
{% set selectedLocale  = client.session.locale  ?? client.currentLocale ?? 'en_US' %}

<main class="relative px-6 py-12">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-5xl">
    {% include 'components/detail_hero.html.twig' with {
      img: image,
      name: champion.name ?? 'Champion',
      sub: champion.title|default('')|capitalize,
      eyebrow: 'champion.list.title'|trans,
      meta_line: 'champion.detail.version_locale'|trans({ '%version%': selectedVersion, '%locale%': selectedLocale })
    } %}

    {# Roles + resource #}
    <section class="mb-8">
      {% if champion.tags is defined %}
        <div class="mb-3 flex flex-wrap gap-2">
          {% for tag in champion.tags %}<span class="hx-chip">{{ tag }}</span>{% endfor %}
        </div>
      {% endif %}
      {% if champion.partype %}
        <p class="font-mono text-xs text-text-muted">{{ 'champion.detail.partype'|trans({'%partype%': champion.partype}) }}</p>
      {% endif %}
    </section>

    {# Base stats #}
    {% if champion.stats is defined %}
      <section class="mb-10">
        <h2 class="mb-4 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">{{ 'champion.detail.stats.title'|trans }}</h2>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-4">
          {% for key, val in champion.stats %}
            <div class="stat-cell">
              <div class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{{ key|replace({'perlevel': ' / lvl'}) }}</div>
              <div class="mt-0.5 font-beaufort text-text">{{ val }}</div>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# Profile ratings #}
    {% if champion.info is defined %}
      <section class="mb-10">
        <h2 class="mb-4 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">{{ 'champion.detail.profile.title'|trans }}</h2>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
          {% set ratings = {
            (('champion.detail.profile.attack')|trans): champion.info.attack,
            (('champion.detail.profile.defense')|trans): champion.info.defense,
            (('champion.detail.profile.magic')|trans): champion.info.magic,
            (('champion.detail.profile.difficulty')|trans): champion.info.difficulty
          } %}
          {% for label, val in ratings %}
            <div class="stat-cell">
              <div class="flex items-baseline justify-between">
                <span class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{{ label }}</span>
                <span class="font-beaufort text-gold">{{ val }}</span>
              </div>
              <div class="mt-2 h-1 bg-void">
                <div class="h-full bg-gradient-to-r from-gold-deep to-gold" style="width: {{ (val|default(0)) * 10 }}%;"></div>
              </div>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# Lore #}
    {% if champion.blurb %}
      <section class="mb-4">
        <h2 class="mb-4 font-beaufort text-sm uppercase tracking-[0.2em] text-gold">{{ 'champion.detail.lore.title'|trans }}</h2>
        <div class="hextech-frame p-6">
          <p class="leading-relaxed text-text">{{ champion.blurb }}</p>
        </div>
      </section>
    {% endif %}

    {% include 'components/detail_actions.html.twig' with { back_href: path('app_champions') } %}
  </div>
</main>
{% endblock %}
