{# templates/champion/liste.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ seo_title('champion.list.title'|trans({}, 'seo')) }}{% endblock %}
{% block meta_description %}{{ 'champion.list.description'|trans({'%count%': meta.totalItem, '%version%': meta.version}, 'seo') }}{% endblock %}
{% block img %}/preview/champions.png{% endblock %}

{% block structured_data %}
  {# First page of entries only — mirrors JsonLdBuilder::ITEM_LIST_MAX; slicing
     here skips building hundreds of throwaway Twig array merges. #}
  {% set seoItems = [] %}
  {% for c in champions|slice(0, 20) %}
    {% set seoItems = seoItems|merge([{
      name: c.name|default(''),
      url: seo_absolute(path('app_champion', { name: c.id|default(c.name) }))
    }]) %}
  {% endfor %}
  {{ seo_jsonld(seo_item_list(seoItems)) }}
{% endblock %}

{% block body %}
<main class="relative px-6 py-12">
  {% include 'partials/main/gradient.html.twig' %}

  <div class="relative mx-auto max-w-[110rem]">
    <header class="mb-8">
      {% include 'components/section_header.html.twig' with {
        eyebrow: 'Data Dragon · ' ~ (client.session.version ?? (client.versions|first)),
        title: 'champion.list.title'|trans,
        count: meta.totalItem,
        count_label: 'champion.list.title'|trans|lower
      } %}
    </header>

    {% include 'components/list_filter.html.twig' with { grid_id: 'champion-grid' } %}

    <div id="champion-grid" class="resource-grid grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {% for c in champions %}
        {% embed 'components/entity_card.html.twig' with {
          href: path('app_champion', { name: c.id|default(c.name), version: meta.version, lang: meta.lang }),
          img: images[loop.index0]|default(null),
          name: c.name|default(''),
          sub: c.title|default('')|capitalize,
          footer_label: 'common.detail'|trans,
          filter_text: (c.name|default('') ~ ' ' ~ c.id|default(''))|lower,
          filter_tags: c.tags|default([])
        } %}
          {% block card_body %}
            <div class="px-4 pb-4">
              {% if c.tags is defined and c.tags is not empty %}
                <div class="mb-2.5 flex flex-wrap gap-1.5">
                  {% for t in c.tags %}<span class="hx-chip">{{ t }}</span>{% endfor %}
                </div>
              {% endif %}
              {% if c.blurb is defined and c.blurb %}
                <p class="line-clamp-3 text-[13px] leading-snug text-text-muted">{{ c.blurb }}</p>
              {% endif %}
            </div>
          {% endblock %}
        {% endembed %}
      {% else %}
        {% include 'components/empty_state.html.twig' %}
      {% endfor %}
    </div>
  </div>
</main>
{% endblock %}
