{% extends 'base.html.twig' %}

{% block title %}{{ 'donate.success.title'|trans }} · {{ 'base.title'|trans }}{% endblock %}
{% block meta_robots %}noindex, follow{% endblock %}

{% block body %}
<main class="donate-page donate-page--outcome">
    <section class="hextech-frame hx-corners donate-panel donate-outcome">
        <span class="donate-seal donate-seal--lit" aria-hidden="true"></span>
        <p class="eyebrow mt-6">{{ 'donate.success.eyebrow'|trans }}</p>
        <h1 class="mt-2 font-beaufort text-3xl font-bold uppercase tracking-wide text-gold-grad">
            {{ 'donate.success.title'|trans }}
        </h1>
        <hr class="hx-rule mx-auto mt-5 max-w-xs">
        <p class="mt-6 text-text-muted">{{ 'donate.success.body'|trans }}</p>
        <p class="mt-3 text-sm text-text-dim">{{ 'donate.success.receipt'|trans }}</p>
        <a href="{{ path('app_home') }}" class="hx-btn-gold mt-8 w-full">{{ 'donate.success.back'|trans }}</a>
    </section>
</main>
{% endblock %}
