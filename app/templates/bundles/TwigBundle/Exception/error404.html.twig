{# Prod-only 404 (TwigBundle override) — rendered outside any controller, so no
   `client` view-model: base.html.twig and the partials degrade gracefully
   (guarded includes, null-safe lookups). Sober Hextech framing, links back in. #}
{% extends 'base.html.twig' %}

{% block title %}{{ seo_title('error.404.title'|trans({}, 'seo')) }}{% endblock %}
{% block meta_description %}{{ 'error.404.body'|trans({}, 'seo') }}{% endblock %}
{% block meta_robots %}noindex, nofollow{% endblock %}
{% block canonical_link %}{% endblock %}

{% block body %}
<main class="relative flex flex-1 items-center justify-center px-6 py-20">
  <div class="hextech-frame relative mx-auto w-full max-w-xl p-10 text-center">
    <p class="eyebrow mb-4">{{ 'error.404.eyebrow'|trans({}, 'seo') }}</p>
    <h1 class="font-beaufort text-7xl uppercase tracking-wide text-gold-bright">404</h1>
    <p class="mt-3 font-beaufort text-xl uppercase tracking-wide text-text">
      {{ 'error.404.title'|trans({}, 'seo') }}
    </p>
    <p class="mx-auto mt-4 max-w-md font-spiegel text-text-muted">
      {{ 'error.404.body'|trans({}, 'seo') }}
    </p>
    <div class="mt-8">
      <a href="{{ path('app_home') }}" class="hx-btn inline-block">{{ 'error.404.back_home'|trans({}, 'seo') }}</a>
    </div>
  </div>
</main>
{% endblock %}
