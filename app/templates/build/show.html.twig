{% extends 'base.html.twig' %}

{# « Parchemin de stratégie » — the public, server-rendered face of a build.
   Reachable by anyone holding the share link (see BuildShareController), so it
   needs no JS beyond the optional copy-link island. Tinted by the primary path. #}

{% set primary = vm.runes.primary %}
{% set secondary = vm.runes.secondary %}
{% set pathClass = {
  'Precision':   'path-precision',
  'Domination':  'path-domination',
  'Sorcery':     'path-sorcery',
  'Resolve':     'path-resolve',
  'Inspiration': 'path-inspiration'
}[primary.key]|default('path-precision') %}

{% block title %}{{ seo_title(build.name ~ ' · ' ~ vm.champion.name) }}{% endblock %}
{% block meta_description %}{{ build.description ? build.description|slice(0, 160) : 'build.show.meta_fallback'|trans({'%champion%': vm.champion.name}) }}{% endblock %}
{% block og_type %}article{% endblock %}
{% block meta_robots %}{{ build.public ? 'index, follow' : 'noindex, nofollow' }}{% endblock %}

{# Emitted only for the indexable (public) render: a private build is an
   unlisted capability link — no Article node, no author leak into the index. #}
{% block structured_data %}
  {% if build.public %}
    {{ seo_jsonld(seo_breadcrumbs([
      { name: 'header.navigation.home'|trans, url: seo_absolute(path('app_home')) },
      { name: 'community.trends.title'|trans, url: seo_absolute(path('app_trends')) },
      { name: build.name, url: seo_canonical() }
    ])) }}
    {{ seo_jsonld(seo_article({
      name: build.name,
      url: seo_canonical(),
      description: build.description ?: null,
      inLanguage: app.request.locale,
      datePublished: build.createdAt|date('c'),
      dateModified: build.updatedAt|date('c'),
      authorName: build.owner.displayName,
      authorUrl: build.owner.publicProfile ? seo_absolute(path('app_profile_public', { username: build.owner.username })) : null,
      about: vm.champion.name
    })) }}
  {% endif %}
{% endblock %}

{% block body %}
<main class="relative px-6 py-12 {{ pathClass }}">
  {% include 'partials/main/gradient.html.twig' %}
  <div aria-hidden="true" class="path-ambient pointer-events-none absolute inset-0"></div>

  <div class="relative mx-auto max-w-4xl">

    {# ================= Header: champion seal + build identity ============= #}
    <header class="bshare-head">
      <div class="bshare-portrait path-glow {{ vm.champion.missing ? 'forge-ghost' }}"
           {% if vm.champion.missing %}title="{{ 'build.show.missing'|trans }}"{% endif %}>
        {% if vm.champion.image %}
          <picture>
            {% if vm.champion.image ends with '.png' %}
              <source srcset="/{{ vm.champion.image|replace({'.png': '.webp'}) }}" type="image/webp">
            {% endif %}
            <img src="/{{ vm.champion.image }}" alt="{{ vm.champion.name }}" width="96" height="96" decoding="async">
          </picture>
        {% else %}
          <span class="bshare-portrait__initials">{{ vm.champion.name|slice(0, 2)|upper }}</span>
        {% endif %}
      </div>

      <div class="min-w-0 flex-1">
        <p class="eyebrow path-text">
          {{ vm.champion.name }}{% if vm.champion.title %} <span class="normal-case tracking-normal text-text-muted">· {{ vm.champion.title }}</span>{% endif %}
        </p>
        <h1 class="mt-1.5 font-beaufort text-3xl font-bold uppercase tracking-wide text-gold-grad sm:text-4xl">
          {{ build.name }}
        </h1>
        <p class="mt-3 flex flex-wrap items-center gap-2 font-mono text-xs text-text-muted">
          {% if build.owner.publicProfile %}
            {# URL keeps the raw username (the tag's # cannot live in a path). #}
            <a class="nav-link text-gold" href="{{ path('app_profile_public', { username: build.owner.username }) }}">
              {{ 'build.show.by'|trans({'%name%': build.owner.displayName}) }}
            </a>
          {% else %}
            <span>{{ 'build.show.by'|trans({'%name%': build.owner.displayName}) }}</span>
          {% endif %}
          {% if build.owner.isSupporter %}{% include 'components/_supporter_badge.html.twig' %}{% endif %}
          <span aria-hidden="true" class="opacity-50">◆</span>
          <span>{{ build.updatedAt|date('d/m/Y') }}</span>
          <span class="hx-chip" title="{{ 'build.show.mode'|trans }}">{{ ('build.mode.' ~ build.gameMode.value)|trans }}</span>
          {% if build.gameVersion %}
            {# The page renders PINNED on the build's patch; the chip is informative. #}
            {% if vm.patchMismatch %}
              <span class="hx-chip">{{ 'build.show.patch_current'|trans({'%version%': build.gameVersion, '%current%': currentVersion}) }}</span>
            {% else %}
              <span class="hx-chip">{{ 'build.show.patch'|trans({'%version%': build.gameVersion}) }}</span>
            {% endif %}
          {% endif %}
          {% if build.language %}<span class="hx-chip">{{ client.languageLabels[build.language]|default(build.language) }}</span>{% endif %}
        </p>
      </div>

      <div class="flex flex-col items-end gap-3">
        {% if voteScore is defined and voteScore is not null %}
          {# Community verdict — public builds only (an unlisted link must not score). #}
          {% include 'components/_vote_score.html.twig' with {
            build: build, score: voteScore, myVote: myVote
          } only %}
        {% endif %}
        <div data-vue="copy-link" data-props="{{ {
              url: url('app_build_show', { token: build.shareToken }),
              labels: {
                copy: 'build.show.copy'|trans,
                copied: 'build.show.copied'|trans,
                error: 'build.show.copy_error'|trans
              }
            }|json_encode|e('html_attr') }}"></div>
      </div>
    </header>

    {% if build.description %}
      <p class="bshare-desc">{{ build.description|nl2br }}</p>
    {% endif %}

    {# ================= Runes ============================================== #}
    <section class="mt-12">
      {% include 'components/codex_header.html.twig' with {
        title: 'build.show.runes'|trans,
        meta: primary.name ~ ' + ' ~ secondary.name
      } %}

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-[1.35fr_1fr]">
        <article class="hextech-frame path-border p-6">
          <p class="bshare-tree path-text">
            {% if primary.icon %}<img src="/{{ primary.icon }}" alt="" width="22" height="22">{% endif %}
            {{ primary.name }}
          </p>
          <div class="mt-5 flex items-center gap-4">
            <div class="keystone__icon {{ primary.keystone.missing ? 'forge-ghost' }}"
                 {% if primary.keystone.missing %}title="{{ 'build.show.missing'|trans }}"{% endif %}>
              {% if primary.keystone.icon %}<img src="/{{ primary.keystone.icon }}" alt="">{% endif %}
            </div>
            <div class="min-w-0">
              <p class="font-mono text-[11px] uppercase tracking-wider text-text-dim">{{ 'build.show.keystone'|trans }}</p>
              <p class="font-beaufort text-lg uppercase tracking-wide text-gold-bright">{{ primary.keystone.name }}</p>
            </div>
          </div>
          <ul class="mt-5 space-y-2.5">
            {% for perk in primary.minors %}
              <li class="flex items-center gap-3 {{ perk.missing ? 'forge-ghost' }}"
                  {% if perk.missing %}title="{{ 'build.show.missing'|trans }}"{% endif %}>
                <span class="rune-medallion bshare-medallion">
                  {% if perk.icon %}<img src="/{{ perk.icon }}" alt="">{% endif %}
                </span>
                <span class="truncate text-sm text-text">{{ perk.name }}</span>
              </li>
            {% endfor %}
          </ul>
        </article>

        <article class="hextech-frame p-6">
          <p class="bshare-tree">
            {% if secondary.icon %}<img src="/{{ secondary.icon }}" alt="" width="22" height="22">{% endif %}
            {{ secondary.name }}
          </p>
          <ul class="mt-5 space-y-2.5">
            {% for perk in secondary.perks %}
              <li class="flex items-center gap-3 {{ perk.missing ? 'forge-ghost' }}"
                  {% if perk.missing %}title="{{ 'build.show.missing'|trans }}"{% endif %}>
                <span class="rune-medallion bshare-medallion">
                  {% if perk.icon %}<img src="/{{ perk.icon }}" alt="">{% endif %}
                </span>
                <span class="truncate text-sm text-text">{{ perk.name }}</span>
              </li>
            {% endfor %}
          </ul>
        </article>
      </div>
    </section>

    {# ================= Purchase order — the page's signature ============== #}
    <section class="mt-12">
      {% include 'components/codex_header.html.twig' with {
        title: 'build.show.order'|trans,
        meta: vm.steps|length ~ ' × ◆'
      } %}

      <ol class="bsteps">
        {% for step in vm.steps %}
          <li class="bsteps-node">
            <span class="bsteps-marker" aria-hidden="true"></span>
            <article class="hextech-frame p-5">
              <header class="flex flex-wrap items-baseline justify-between gap-2">
                <h3 class="font-beaufort text-base uppercase tracking-wide text-gold-bright">{{ step.label }}</h3>
                <span class="hx-chip" title="{{ 'build.show.step_cost'|trans }}">{{ step.gold }} ◆</span>
              </header>
              {% if step.note %}
                <p class="mt-2 font-spiegel text-sm italic text-text-muted">{{ step.note }}</p>
              {% endif %}
              <ul class="mt-4 flex flex-wrap gap-2.5">
                {% for item in step.items %}
                  <li class="bshare-item {{ item.missing ? 'forge-ghost' }}"
                      title="{{ item.missing ? 'build.show.missing'|trans : item.name }}">
                    {% if item.image %}
                      <picture>
                        {% if item.image ends with '.png' %}
                          <source srcset="/{{ item.image|replace({'.png': '.webp'}) }}" type="image/webp">
                        {% endif %}
                        <img src="/{{ item.image }}" alt="{{ item.name }}" width="48" height="48" loading="lazy" decoding="async">
                      </picture>
                    {% else %}
                      <span class="bshare-item__fallback">{{ item.name|slice(0, 2) }}</span>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            </article>
          </li>
        {% endfor %}
      </ol>

      <div class="hx-plate mt-8">
        <span class="hx-plate__label">{{ 'build.show.total'|trans }}</span>
        <span class="hx-plate__value">{{ vm.totalGold }} ◆</span>
      </div>
    </section>
  </div>
</main>
{% endblock %}
