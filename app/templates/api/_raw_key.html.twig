{# One-shot reveal of the freshly issued secret (flash-fed, gone on reload).
   Copy button reuses the copy-link island; the readonly field is the no-JS
   fallback and the visual proof of what was generated. #}
<section class="hextech-frame hx-corners api-reveal" aria-labelledby="api-raw-title">
    <h2 id="api-raw-title" class="profile-panel__title">{{ 'portal.raw.title'|trans({}, 'api') }}</h2>
    <p class="api-reveal__warning">{{ 'portal.raw.warning'|trans({}, 'api') }}</p>
    <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
        <label class="flex-1">
            <span class="auth-label">{{ 'portal.raw.label'|trans({}, 'api') }}</span>
            <input type="text" readonly value="{{ plainKey }}" class="hx-input mt-1.5 w-full font-mono text-xs">
        </label>
        <div data-vue="copy-link" data-props="{{ {
            url: plainKey,
            labels: {
                copy: 'portal.raw.copy'|trans({}, 'api'),
                copied: 'portal.raw.copied'|trans({}, 'api'),
                error: 'portal.raw.copy_error'|trans({}, 'api'),
            },
        }|json_encode|e('html_attr') }}"></div>
    </div>
</section>
