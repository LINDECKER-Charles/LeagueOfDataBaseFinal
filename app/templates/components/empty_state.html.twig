{# Unified empty state — replaces the per-entity noResult partials. Param: text (optional) #}
<div class="col-span-full hextech-frame p-10 text-center">
  <p class="eyebrow mb-3">{{ 'common.no_result.text'|trans }}</p>
  {% if text is defined and text %}<p class="mx-auto max-w-md text-sm text-text-muted">{{ text }}</p>{% endif %}
  <div class="mt-6 flex items-center justify-center gap-3">
    <a href="javascript:history.back()" class="hx-btn-ghost">{{ 'common.no_result.back'|trans }}</a>
    <a href="{{ path('app_home') }}" class="hx-btn">{{ 'header.navigation.home'|trans }}</a>
  </div>
</div>
