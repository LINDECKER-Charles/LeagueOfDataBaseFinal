{# Detail page hero — framed portrait + title. Params: img, name, sub, eyebrow, meta_line, img_fit, img_scale #}
<article class="mb-10 flex items-center gap-5 sm:gap-6">
  {% if img %}
    <div class="hextech-frame relative h-24 w-24 shrink-0 overflow-hidden sm:h-28 sm:w-28">
      <img src="/{{ img }}" alt="{{ name }}"
           class="absolute inset-0 h-full w-full {{ img_fit|default('cover') == 'contain' ? 'object-contain p-2' : 'object-cover' }}"
           {% if img_scale is defined %}style="transform: scale({{ img_scale }});"{% endif %}>
    </div>
  {% else %}
    <div class="hextech-frame grid h-24 w-24 shrink-0 place-items-center font-beaufort text-xl text-gold/70 sm:h-28 sm:w-28">
      {{ name|slice(0, 2)|upper }}
    </div>
  {% endif %}

  <div class="min-w-0">
    {% if eyebrow is defined and eyebrow %}<p class="eyebrow mb-2">{{ eyebrow }}</p>{% endif %}
    <h1 class="font-beaufort text-3xl uppercase leading-tight tracking-wide text-gold-bright sm:text-4xl">{{ name }}</h1>
    {% if sub is defined and sub %}<p class="mt-1.5 font-spiegel text-text-muted">{{ sub }}</p>{% endif %}
    {% if meta_line is defined and meta_line %}<p class="mt-1.5 font-mono text-xs text-text-dim">{{ meta_line }}</p>{% endif %}
  </div>
</article>
