{# Embeddable Hextech card shell — factors out the frame/header/footer shared by
   the champion / item / summoner / rune cards. Fill {% block card_body %} in the caller.
   Params: href, img, name, sub, initials, img_fit ('cover'|'contain'), img_scale, footer_href, footer_label
   Filtering (optional): filter_text (searchable string), filter_tags (list) — read by the
   ResourceFilter island to search/facet the grid client-side. #}
<section class="hextech-frame hextech-frame-hover group flex h-full flex-col overflow-hidden"
  {% if filter_text is defined %}data-search="{{ filter_text }}"{% endif %}
  {% if filter_tags is defined %}data-tags="{{ filter_tags|join('|') }}"{% endif %}>
  <a href="{{ href|default('#') }}" class="flex items-center gap-3 px-4 pb-3 pt-4">
    {% if img %}
      <div class="relative h-14 w-14 shrink-0 overflow-hidden border border-gold-deep/50 bg-void">
        <picture>
          {% if img ends with '.png' %}<source srcset="/{{ img|replace({'.png': '.webp'}) }}" type="image/webp">{% endif %}
          <img src="/{{ img }}" alt="{{ name }}" width="56" height="56" loading="lazy" decoding="async"
               class="absolute inset-0 h-full w-full {{ img_fit|default('cover') == 'contain' ? 'object-contain' : 'object-cover' }} transition-transform duration-500 group-hover:scale-110"
               {% if img_scale is defined %}style="transform: scale({{ img_scale }});"{% endif %}>
        </picture>
      </div>
    {% else %}
      <div class="grid h-14 w-14 shrink-0 place-items-center border border-gold-deep/50 bg-void font-beaufort text-sm text-gold/70">
        {{ initials|default(name|slice(0, 2)|upper) }}
      </div>
    {% endif %}
    <div class="min-w-0">
      <h3 class="truncate font-beaufort text-[15px] tracking-wide text-text transition-colors group-hover:text-gold-bright" title="{{ name }}">{{ name }}</h3>
      {% if sub %}<p class="truncate font-mono text-xs text-text-muted" title="{{ sub }}">{{ sub }}</p>{% endif %}
    </div>
  </a>

  {% block card_body %}{% endblock %}

  {% if footer_label is defined %}
    <footer class="mt-auto gold-rule">
      <a href="{{ footer_href|default(href) }}"
         class="block py-2.5 text-center font-beaufort text-xs uppercase tracking-[0.2em] text-gold/80 transition-colors hover:text-gold-bright">
        {{ footer_label }}
      </a>
    </footer>
  {% endif %}
</section>
