{# templates/home/home.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans({}, 'seo') }}{% endblock %}
{% block meta_description %}{{ 'home.description'|trans({'%version%': client.session.version ?? (client.versions|first)}, 'seo') }}{% endblock %}
{% block img %}/preview/home.png{% endblock %}

{% block body %}
{% set navVersion = client.session.version ?? (client.versions|default([])|first) %}
{% set navLang = client.session.locale ?? client.currentLocale ?? 'en_US' %}
<main class="relative px-6 py-14">
  {% include 'partials/main/gradient.html.twig' %}
  <div class="relative mx-auto flex max-w-7xl flex-col gap-16">

    {# HERO #}
    <section class="text-center">
      <p class="eyebrow mb-4">Patch {{ client.session.version ?? (client.versions|first) }}</p>
      <h1 class="font-beaufort text-4xl uppercase tracking-wide text-gold-bright sm:text-6xl">
        {{ 'homepage.title'|trans }}
      </h1>
      <p class="mx-auto mt-5 max-w-2xl font-spiegel text-text-muted">
        {{ 'homepage.hero.browse'|trans({'%version%': client.session.version ?? (client.versions|first)})|raw }}
      </p>

      {# Category portals — the gateway into each dataset #}
      {% set portals = [
        { href: resource_path('app_champions', {}, navVersion, navLang), label: 'homepage.champions.title', cta: 'homepage.champions.see_all' },
        { href: resource_path('app_items', {}, navVersion, navLang),     label: 'homepage.items.title',     cta: 'homepage.items.see_all' },
        { href: resource_path('app_runes', {}, navVersion, navLang),     label: 'homepage.runes.title',     cta: 'homepage.runes.see_all' },
        { href: resource_path('app_summoners', {}, navVersion, navLang), label: 'homepage.summoners.title', cta: 'homepage.summoners.see_all' }
      ] %}
      <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {% for p in portals %}
          <a href="{{ p.href }}" class="hextech-frame hextech-frame-hover group flex flex-col items-start gap-3 p-6 text-left">
            <span class="text-gold/80 transition-colors group-hover:text-gold">
              {% include 'components/logo.html.twig' with { class: 'h-8 w-8' } %}
            </span>
            <span class="font-beaufort text-xl uppercase tracking-wide text-text transition-colors group-hover:text-gold-bright">
              {{ p.label|trans }}
            </span>
            <span class="mt-auto inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-hex">
              {{ p.cta|trans }}
              <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        {% endfor %}
      </div>
    </section>

    {# CHAMPIONS PREVIEW #}
    <section>
      {% include 'home/_preview_header.html.twig' with { title: 'homepage.champions.title'|trans, href: resource_path('app_champions', {}, navVersion, navLang), link: 'homepage.champions.see_all'|trans } %}
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {% for key, c in champions.champions|slice(0, 4) %}
          {% include 'components/entity_card.html.twig' with {
            href: resource_path('app_champion', { name: key }, navVersion, navLang),
            img: champions.images[loop.index0]|default(null),
            name: c.name,
            sub: c.title|default('')
          } %}
        {% else %}
          {% include 'components/empty_state.html.twig' with { text: 'homepage.champions.no_data'|trans } %}
        {% endfor %}
      </div>
    </section>

    {# ITEMS PREVIEW #}
    <section>
      {% include 'home/_preview_header.html.twig' with { title: 'homepage.items.title'|trans, href: resource_path('app_items', {}, navVersion, navLang), link: 'homepage.items.see_all'|trans } %}
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {% for key, i in items.items %}
          {% include 'components/entity_card.html.twig' with {
            href: resource_path('app_item', { name: key }, navVersion, navLang),
            img: items.images[i.name]|default(null),
            name: i.name,
            sub: key,
            img_fit: 'contain'
          } %}
        {% endfor %}
      </div>
    </section>

    {# SUMMONERS PREVIEW #}
    <section>
      {% include 'home/_preview_header.html.twig' with { title: 'homepage.summoners.title'|trans, href: resource_path('app_summoners', {}, navVersion, navLang), link: 'homepage.summoners.see_all'|trans } %}
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {% for key, s in summoners.summoners %}
          {% include 'components/entity_card.html.twig' with {
            href: resource_path('app_summoner', { name: key }, navVersion, navLang),
            img: summoners.images[key]|default(null),
            name: s.name,
            sub: key,
            img_fit: 'contain'
          } %}
        {% endfor %}
      </div>
    </section>

    {# RUNES PREVIEW #}
    <section>
      {% include 'home/_preview_header.html.twig' with { title: 'homepage.runes.title'|trans, href: resource_path('app_runes', {}, navVersion, navLang), link: 'homepage.runes.see_all'|trans } %}
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {% for r in runes.runesReforgeds|slice(0, 4) %}
          {% include 'components/entity_card.html.twig' with {
            href: resource_path('app_rune', { name: r.key }, navVersion, navLang),
            img: runes.images[r.key].icon ?? null,
            name: r.name,
            sub: r.key,
            img_scale: 0.72
          } %}
        {% else %}
          {% include 'components/empty_state.html.twig' with { text: 'homepage.runes.no_data'|trans } %}
        {% endfor %}
      </div>
    </section>

  </div>
</main>
{% endblock %}
