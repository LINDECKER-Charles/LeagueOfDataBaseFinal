{% extends 'base.html.twig' %}

{% block title %}{{ 'setup.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'setup.meta'|trans }}{% endblock %}
{% block img %}/preview/setup.png{% endblock %}

{% block body %}
<main class="relative flex min-h-[80vh] items-center justify-center overflow-hidden px-4 py-16" id="content">
  {% include 'partials/main/gradient.html.twig' %}

  {% set selectedLocale  = client.session.locale  ?? client.currentLocale ?? 'en_US' %}
  {% set selectedVersion = client.session.version ?? (client.versions|first) %}

  <section class="relative w-full max-w-xl">
    {# Intro #}
    <div class="mb-8 text-center">
      <p class="eyebrow mb-4">{{ 'header.navigation.home'|trans }} · Data Dragon</p>
      <h1 class="font-beaufort text-4xl uppercase leading-tight tracking-wide text-gold-bright sm:text-5xl">
        League Of Data Base
      </h1>
      <div class="mx-auto mt-4 h-px w-40 bg-gradient-to-r from-transparent via-gold to-transparent"></div>
    </div>

    {# Console #}
    <div class="hextech-frame p-8 sm:p-10">
      <form action="{{ path('app_setup_save') }}" method="post" class="flex w-full flex-col gap-9">
        {# Version #}
        <div class="flex flex-col items-center gap-3">
          <label for="version" class="eyebrow">{{ 'setup.form.version'|trans }}</label>
          <select id="version" name="version" class="hx-select w-full text-center text-lg">
            {% for version in client.versions %}
              <option value="{{ version }}" {{ version == selectedVersion ? 'selected' : '' }}>{{ version }}</option>
            {% endfor %}
          </select>
        </div>

        {# Language #}
        <div class="flex flex-col items-center gap-3">
          <label for="langue" class="eyebrow">{{ 'setup.form.language'|trans }}</label>
          <select id="langue" name="langue" class="hx-select w-full text-center text-lg">
            {% for lang in client.languages %}
              <option value="{{ lang }}" {{ lang == selectedLocale ? 'selected' : '' }}>{{ client.languageLabels[lang] ?? lang }}</option>
            {% endfor %}
          </select>
          <p class="mt-1 text-center text-xs italic text-text-muted">{{ 'setup.form.note_latest'|trans }}</p>
        </div>

        {# Remember #}
        <label for="remember" class="flex cursor-pointer select-none items-center justify-center gap-3 text-sm text-text-muted">
          <input type="checkbox" id="remember" name="remember" class="hx-check">
          <span class="italic">{{ 'setup.form.remember'|trans }}</span>
        </label>

        {# Submit #}
        <button type="submit" class="hx-btn w-full py-4 text-base">
          {{ 'setup.form.submit'|trans }}
        </button>
      </form>
    </div>
  </section>
</main>
{% endblock %}
