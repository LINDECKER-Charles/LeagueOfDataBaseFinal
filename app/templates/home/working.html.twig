{# templates/system/under_construction.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'system.under_construction.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'system.under_construction.meta_description'|trans }}{% endblock %}
{% block img %}/preview/working.png{% endblock %}
{% block meta_robots %}noindex, nofollow{% endblock %}

{% block body %}
<main class="relative flex min-h-[65vh] items-center justify-center overflow-hidden px-6 py-16">
  {% include 'partials/main/gradient.html.twig' %}

  <section class="relative mx-auto w-full max-w-4xl">
    <header class="mb-10 flex items-center gap-5">
      <div class="hextech-frame relative grid h-16 w-16 shrink-0 place-items-center text-gold">
        <div class="absolute inset-0 opacity-40 blur-lg" style="background: radial-gradient(closest-side, rgba(10,200,185,0.35), transparent);"></div>
        {% include 'components/logo.html.twig' with { class: 'relative z-10 h-8 w-8' } %}
      </div>
      <div>
        <p class="eyebrow mb-1.5">Data Dragon</p>
        <h1 class="font-beaufort text-3xl uppercase tracking-wide text-gold-bright sm:text-4xl">{{ 'system.under_construction.heading'|trans }}</h1>
        <p class="mt-1 font-spiegel text-text-muted">{{ 'system.under_construction.subheading'|trans }}</p>
      </div>
    </header>

    <div class="hextech-frame p-8">
      <div class="grid gap-8 lg:grid-cols-3">
        <div class="space-y-6 lg:col-span-2">
          <p class="leading-relaxed text-text">{{ 'system.under_construction.info'|trans }}</p>

          <div>
            <div class="mb-2 flex items-center justify-between font-mono text-[11px] uppercase tracking-wider text-text-muted">
              <span>{{ 'system.under_construction.progress_label'|trans }}</span>
              <span class="text-hex">~10%</span>
            </div>
            <div class="relative h-2 overflow-hidden border border-gold-deep/40 bg-void">
              <div class="absolute inset-y-0 left-0 w-[60%] bg-gradient-to-r from-gold-deep via-gold to-hex"></div>
            </div>
          </div>
        </div>

        <aside class="flex flex-col gap-3 border-l border-gold-deep/25 pl-6">
          <p class="font-mono text-[11px] uppercase tracking-wider text-text-muted">{{ 'system.under_construction.meanwhile'|trans }}</p>
          <a href="javascript:history.back()" class="hx-btn-ghost">{{ 'system.under_construction.back'|trans }}</a>
          <a href="{{ path('app_summoners') }}" class="hx-btn-ghost">{{ 'system.under_construction.summoners'|trans }}</a>
          <a href="{{ path('app_home') }}" class="hx-btn">{{ 'header.navigation.home'|trans }}</a>
        </aside>
      </div>
    </div>

    <p class="mt-8 text-center font-mono text-xs text-text-dim">{{ 'system.under_construction.footer'|trans }}</p>
  </section>
</main>
{% endblock %}
