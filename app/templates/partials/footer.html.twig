<footer class="relative border-t border-gold-deep/40 bg-hextech-black/95 text-text-muted">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gold/50 to-transparent"></div>

  <div class="mx-auto grid max-w-[110rem] grid-cols-2 gap-x-6 gap-y-10 px-6 py-12 sm:px-8 sm:py-14 lg:grid-cols-6">
    {# Brand + copyright #}
    <div class="col-span-2 flex flex-col gap-3 lg:col-span-1">
      <div class="flex items-center gap-2 text-gold">
        {% include 'components/logo.html.twig' with { class: 'h-7 w-7' } %}
        <span class="font-beaufort text-sm uppercase tracking-[0.16em] text-gold-bright">Data Base</span>
      </div>
      <p class="text-sm">{{ 'footer.copyright'|trans }}</p>
      <p><a href="{{ path('app_legal_notice') }}" class="nav-link underline-offset-4 hover:underline">{{ 'footer.legal'|trans }}</a></p>
    </div>

    {# Navigation #}
    <div>
      <h3 class="eyebrow mb-3">{{ 'footer.navigation.title'|trans }}</h3>
      {% set navVersion = app.request.attributes.get('version') ?: (client.session.version ?? (client.versions|default([])|first)) %}
      {% set navLang = client.session.locale ?? client.currentLocale ?? 'en_US' %}
      <ul class="flex flex-col gap-1.5 text-sm">
        <li><a href="{{ path('app_home') }}" class="nav-link">{{ 'footer.navigation.home'|trans }}</a></li>
        <li><a href="{{ resource_path('app_champions', {}, navVersion, navLang) }}" class="nav-link">{{ 'footer.navigation.champion'|trans }}</a></li>
        <li><a href="{{ resource_path('app_items', {}, navVersion, navLang) }}" class="nav-link">{{ 'footer.navigation.item'|trans }}</a></li>
        <li><a href="{{ resource_path('app_runes', {}, navVersion, navLang) }}" class="nav-link">{{ 'footer.navigation.runes'|trans }}</a></li>
        <li><a href="{{ resource_path('app_summoners', {}, navVersion, navLang) }}" class="nav-link">{{ 'footer.navigation.summoner'|trans }}</a></li>
        <li><a href="{{ path('app_donate') }}" class="nav-link">{{ 'nav.donate'|trans }}</a></li>
        <li><a href="{{ path('app_developers') }}" class="nav-link">{{ 'nav.developers'|trans({}, 'api') }}</a></li>
        {% if app.user %}
          <li><a href="{{ path('app_profile') }}" class="nav-link">{{ 'nav.profile'|trans }}</a></li>
        {% endif %}
        <li><a href="{{ path('app_sitemap') }}" class="nav-link">{{ 'footer.navigation.sitemap'|trans }}</a></li>
      </ul>
    </div>

    {# External links #}
    <div>
      <h3 class="eyebrow mb-3">{{ 'footer.links.title'|trans }}</h3>
      <ul class="flex flex-col gap-1.5 text-sm">
        <li><a href="https://www.leagueoflegends.com/en-us/" target="_blank" rel="noopener noreferrer" class="nav-link">{{ 'footer.links.lol'|trans }}</a></li>
        <li><a href="https://developer.riotgames.com/" target="_blank" rel="noopener noreferrer" class="nav-link">{{ 'footer.links.riotapi'|trans }}</a></li>
        <li><a href="https://ddragon.leagueoflegends.com/" target="_blank" rel="noopener noreferrer" class="nav-link">{{ 'footer.links.ddragon'|trans }}</a></li>
        <li><a href="https://support-leagueoflegends.riotgames.com/" target="_blank" rel="noopener noreferrer" class="nav-link">{{ 'footer.links.support'|trans }}</a></li>
        <li><a href="https://www.op.gg/" target="_blank" rel="noopener noreferrer" class="nav-link">{{ 'footer.links.opgg'|trans }}</a></li>
      </ul>
    </div>

    {# Project info #}
    <div>
      <h3 class="eyebrow mb-3">{{ 'footer.project.title'|trans }}</h3>
      <ul class="flex flex-col gap-1.5 text-sm">
        <li>{{ 'footer.project.version'|trans }}</li>
        <li>{{ 'footer.project.updated'|trans }}</li>
      </ul>
    </div>

    {# Legal #}
    <div>
      <h3 class="eyebrow mb-3">{{ 'footer.legal_title'|trans }}</h3>
      <ul class="flex flex-col gap-1.5 text-sm">
        <li><a href="{{ path('app_legal_notice') }}" class="nav-link">{{ 'legal.notice.title'|trans }}</a></li>
        <li><a href="{{ path('app_legal_privacy') }}" class="nav-link">{{ 'legal.privacy.title'|trans }}</a></li>
        <li><a href="{{ path('app_legal_terms') }}" class="nav-link">{{ 'legal.terms.title'|trans }}</a></li>
        <li><a href="{{ path('app_legal_cookies') }}" class="nav-link">{{ 'legal.cookies.title'|trans }}</a></li>
      </ul>
    </div>

    {# Contact #}
    <div class="col-span-2 lg:col-span-1">
      <h3 class="eyebrow mb-3">{{ 'footer.contact.title'|trans }}</h3>
      <ul class="flex flex-col gap-2.5 text-sm">
        <li>
          <a href="mailto:charles.lindecker@outlook.fr" class="nav-link inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="h-5 w-5">
              <rect x="3" y="5" width="18" height="14" rx="2" ry="2"/><path d="M3 7l9 6 9-6"/>
            </svg>
            {{ 'footer.contact.email'|trans }}
          </a>
        </li>
        <li>
          <a href="https://github.com/LINDECKER-Charles" target="_blank" rel="noopener noreferrer" class="nav-link inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5">
              <path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.757-1.333-1.757-1.09-.745.083-.73.083-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.49.997.108-.776.42-1.305.763-1.605-2.665-.304-5.467-1.335-5.467-5.933 0-1.31.468-2.382 1.235-3.22-.124-.303-.536-1.523.117-3.176 0 0 1.008-.322 3.3 1.23a11.5 11.5 0 0 1 3.003-.404c1.02.005 2.045.138 3.003.404 2.29-1.552 3.296-1.23 3.296-1.23.655 1.653.243 2.873.12 3.176.77.838 1.233 1.91 1.233 3.22 0 4.61-2.807 5.625-5.48 5.922.43.37.816 1.1.816 2.22 0 1.604-.015 2.896-.015 3.286 0 .322.216.694.825.576C20.565 21.795 24 17.298 24 12 24 5.373 18.627 0 12 0Z"/>
            </svg>
            {{ 'footer.contact.github'|trans }}
          </a>
        </li>
        <li>
          <a href="https://github.com/LINDECKER-Charles/LeagueOfDataBaseFinal" target="_blank" rel="noopener noreferrer" class="nav-link inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="h-5 w-5">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
            {{ 'footer.contact.repo'|trans }}
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/in/charles-lindecker" target="_blank" rel="noopener noreferrer" class="nav-link inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5">
              <path d="M22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.226.792 24 1.771 24h20.451C23.2 24 24 23.226 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003zM6.814 20.452H3.861V9h2.953v11.452zM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124zM20.447 20.452h-3.554v-5.569c0-1.328-.024-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.049c.476-.9 1.637-1.852 3.369-1.852 3.602 0 4.267 2.371 4.267 5.455v6.288z"/>
            </svg>
            {{ 'footer.contact.linkedin'|trans }}
          </a>
        </li>
      </ul>
      <button type="button" class="hx-btn-gold mt-4 w-full justify-center" data-contact-open>
        {{ 'contact.form.cta'|trans }}
      </button>
    </div>
  </div>

  {# Riot Games boilerplate disclaimer — standard wording, kept in English #}
  <div class="mx-auto max-w-[110rem] px-6 pb-8 sm:px-8">
    <p class="border-t border-gold-deep/25 pt-5 text-xs leading-relaxed text-text-dim">
      League Of Data Base isn't endorsed by Riot Games and doesn't reflect the views or opinions of Riot Games
      or anyone officially involved in producing or managing Riot Games properties. Riot Games and all associated
      properties are trademarks or registered trademarks of Riot Games, Inc.
    </p>
  </div>

  {# Contact form — native <dialog>, opened by [data-contact-open] (fx/enhance.ts).
     Plain POST (data-turbo=false) that redirects back with a flash toaster. #}
  <dialog id="contact-dialog" class="contact-dialog" aria-labelledby="contact-dialog-title">
    <form method="post" action="{{ path('app_contact_submit') }}" data-turbo="false" class="flex flex-col gap-4 p-6 sm:p-7">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="eyebrow">{{ 'contact.form.eyebrow'|trans }}</p>
          <h2 id="contact-dialog-title" class="font-beaufort text-lg text-gold-bright">{{ 'contact.form.title'|trans }}</h2>
        </div>
        <button type="button" class="nav-link text-2xl leading-none" data-contact-close aria-label="{{ 'contact.form.close'|trans }}">&times;</button>
      </div>
      <p class="text-sm text-text-muted">{{ 'contact.form.intro'|trans }}</p>

      <input type="hidden" name="_token" value="{{ csrf_token('contact') }}">
      <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">
      {# Honeypot: off-screen for humans, tempting to bots. A filled value is dropped server-side. #}
      <div class="absolute h-px w-px -left-[9999px] overflow-hidden" aria-hidden="true">
        <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
      </div>

      <label class="flex flex-col gap-1.5 text-sm">
        <span class="text-text-muted">{{ 'contact.form.category'|trans }}</span>
        <select name="category" required class="hx-select w-full">
          <option value="bug">{{ 'contact.form.category_bug'|trans }}</option>
          <option value="feedback">{{ 'contact.form.category_feedback'|trans }}</option>
          <option value="review">{{ 'contact.form.category_review'|trans }}</option>
          <option value="commercial">{{ 'contact.form.category_commercial'|trans }}</option>
        </select>
      </label>

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="flex flex-col gap-1.5 text-sm">
          <span class="text-text-muted">{{ 'contact.form.name'|trans }}</span>
          <input type="text" name="name" maxlength="120" autocomplete="name" class="hx-input">
        </label>
        <label class="flex flex-col gap-1.5 text-sm">
          <span class="text-text-muted">{{ 'contact.form.email'|trans }} *</span>
          <input type="email" name="email" required maxlength="255" autocomplete="email" class="hx-input">
        </label>
      </div>

      <label class="flex flex-col gap-1.5 text-sm">
        <span class="text-text-muted">{{ 'contact.form.subject'|trans }}</span>
        <input type="text" name="subject" maxlength="160" class="hx-input">
      </label>

      <label class="flex flex-col gap-1.5 text-sm">
        <span class="text-text-muted">{{ 'contact.form.message'|trans }} *</span>
        <textarea name="message" required minlength="10" maxlength="5000" rows="5" class="hx-input resize-y"></textarea>
      </label>

      <div class="flex items-center justify-end gap-3 pt-1">
        <button type="button" class="hx-btn-ghost" data-contact-close>{{ 'contact.form.cancel'|trans }}</button>
        <button type="submit" class="hx-btn-gold">{{ 'contact.form.submit'|trans }}</button>
      </div>
    </form>
  </dialog>
</footer>
