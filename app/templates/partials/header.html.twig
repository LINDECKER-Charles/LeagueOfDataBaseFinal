{# Global header — Hextech bar. The version/language form shows only on the setup
   context (typeV undefined); inner pages carry their own switcher in the action bar. #}
<header class="relative z-30 border-b border-gold-deep/40 bg-hextech-black/95 backdrop-blur">
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold/60 to-transparent"></div>

  <div class="mx-auto flex max-w-[110rem] flex-col items-center gap-6 px-6 py-5 lg:flex-row lg:gap-10">
    {# Brand #}
    <a href="{{ url('app_setup') }}" class="brand-link group flex items-center gap-3">
      <span class="brand-logo text-gold">{% include 'components/logo.html.twig' with { class: 'h-9 w-9' } %}</span>
      <span class="brand-title font-beaufort text-lg uppercase tracking-[0.18em] text-gold-bright sm:text-xl">League Of Data Base</span>
    </a>

    {# Navigation #}
    <nav class="flex flex-1 justify-center {% if typeV is defined %}lg:justify-end{% else %}lg:justify-center{% endif %}">
      {% set navVersion = client.session.version ?? (client.versions|default([])|first) %}
      {% set navLang = client.session.locale ?? client.currentLocale ?? 'en_US' %}
      <ul class="flex flex-wrap items-center justify-center gap-x-7 gap-y-2 font-beaufort text-sm uppercase tracking-[0.15em] text-text-muted">
        <li><a href="{{ path('app_home') }}" class="nav-link">{{ 'header.navigation.home'|trans }}</a></li>
        <li><a href="{{ path('app_champions', {version: navVersion, lang: navLang}) }}" class="nav-link">{{ 'header.navigation.champion'|trans }}</a></li>
        <li><a href="{{ path('app_items', {version: navVersion, lang: navLang}) }}" class="nav-link">{{ 'header.navigation.item'|trans }}</a></li>
        <li><a href="{{ path('app_runes', {version: navVersion, lang: navLang}) }}" class="nav-link">{{ 'header.navigation.runes'|trans }}</a></li>
        <li><a href="{{ path('app_summoners', {version: navVersion, lang: navLang}) }}" class="nav-link">{{ 'header.navigation.summoner'|trans }}</a></li>
      </ul>
    </nav>

    {% if typeV is not defined %}
      {% set selectedLocale  = client.session.locale  ?? client.currentLocale ?? 'en_US' %}
      {% set selectedVersion = client.session.version ?? (client.versions|default([])|first) %}

      <form action="{{ path('app_setup_save') }}" method="post" class="flex w-full max-w-md flex-col gap-2 lg:w-auto lg:min-w-[22rem]">
        <div class="flex items-center gap-2">
          <label for="version" class="sr-only">{{ 'setup.form.version'|trans }}</label>
          <select id="version" name="version" class="hx-select flex-1">
            {% for v in client.versions %}
              <option value="{{ v }}" {{ v == selectedVersion ? 'selected' : '' }}>{{ v }}</option>
            {% endfor %}
          </select>

          <label for="langue" class="sr-only">{{ 'setup.form.language'|trans }}</label>
          <select id="langue" name="langue" class="hx-select flex-1">
            {% for lang in client.languages %}
              <option value="{{ lang }}" {{ lang == selectedLocale ? 'selected' : '' }}>{{ client.languageLabels[lang] ?? lang }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="flex items-center gap-3">
          <label for="remember" class="flex cursor-pointer select-none items-center gap-2 text-xs text-text-muted">
            <input type="checkbox" id="remember" name="remember" class="hx-check">
            <span>{{ 'setup.form.remember'|trans }}</span>
          </label>
          <button type="submit" class="hx-btn ml-auto py-2">{{ 'setup.form.submit'|trans }}</button>
        </div>
      </form>
    {% endif %}
  </div>
</header>
