{% macro plink(page, meta, route) %}
  {% set active = page == meta.currentPage %}
  <a href="{{ path(route, { version: meta.version, lang: meta.lang, numpage: page, itemperpage: meta.itemPerPage }) }}"
     class="inline-flex h-9 min-w-9 items-center justify-center px-3 font-mono text-sm transition-colors
            {{ active
                ? 'border border-gold/70 bg-gold/15 text-gold-bright'
                : 'border border-gold-deep/40 bg-void/60 text-text-muted hover:border-hex/60 hover:text-hex' }}">
    {{ page }}
  </a>
{% endmacro %}

{% import _self as pg %}
{% set route = route|default('app_' ~ meta.type ~ 's') %}

{% if meta.nombrePage > 1 %}
<nav class="mt-12 flex flex-wrap items-center justify-center gap-2">
  {# First two #}
  {% for page in 1..2 %}
    {% if page <= meta.nombrePage %}{{ pg.plink(page, meta, route) }}{% endif %}
  {% endfor %}

  {% set start = max(meta.currentPage - 1, 3) %}
  {% set end   = min(meta.currentPage + 1, meta.nombrePage - 2) %}

  {% if start > 3 %}<span class="px-1 font-mono text-gold/60">…</span>{% endif %}

  {% for page in start..end %}
    {% if page > 2 and page < meta.nombrePage - 1 %}{{ pg.plink(page, meta, route) }}{% endif %}
  {% endfor %}

  {% if end < meta.nombrePage - 2 %}<span class="px-1 font-mono text-gold/60">…</span>{% endif %}

  {# Last two #}
  {% for page in (meta.nombrePage - 1)..meta.nombrePage %}
    {% if page > 2 %}{{ pg.plink(page, meta, route) }}{% endif %}
  {% endfor %}

  {# Jump-to-page island (replaces the legacy inline oninput hack) #}
  <div class="ml-2" data-vue="number-nav" data-props="{{ {
        pathTemplate: path(route, { version: meta.version, lang: meta.lang, numpage: '__P__', itemperpage: meta.itemPerPage }),
        min: 1,
        max: meta.nombrePage,
        value: meta.currentPage,
        label: 'pagination.ok'|trans
      }|json_encode|e('html_attr') }}"></div>
</nav>
{% endif %}
