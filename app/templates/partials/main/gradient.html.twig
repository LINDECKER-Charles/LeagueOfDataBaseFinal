{# Ambient Hextech backdrop — cyan/gold glows + hexagonal weave + vignette.
   Included by list/detail/home pages, so restyling it here upgrades them all. #}
<div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
  <div class="hx-breathe absolute -top-1/3 left-1/2 h-[62rem] w-[62rem] rounded-full blur-3xl"
       style="background: radial-gradient(closest-side, rgba(10,200,185,0.20), rgba(3,151,171,0.08) 45%, transparent 72%);"></div>
  <div class="absolute right-0 top-1/4 h-[34rem] w-[34rem] rounded-full opacity-20 blur-3xl"
       style="background: radial-gradient(closest-side, rgba(200,170,110,0.16), transparent 70%);"></div>

  <svg class="absolute inset-0 h-full w-full opacity-[0.05]" aria-hidden="true">
    <defs>
      <pattern id="hexweave" width="56" height="48" patternUnits="userSpaceOnUse">
        <path d="M14 1 L42 1 L56 24 L42 47 L14 47 L0 24 Z" fill="none" stroke="#c8aa6e" stroke-width="1"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#hexweave)"/>
  </svg>

  <div class="absolute inset-0" style="background: radial-gradient(120% 80% at 50% 0%, transparent 55%, rgba(1,10,19,0.55));"></div>
</div>
