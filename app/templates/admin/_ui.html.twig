{# Reusable Hextech admin widgets. Presentation only — all numbers are computed
   server-side; charts come from the AdminChartExtension (chart_* functions). #}

{% macro page_head(eyebrow, title, subtitle) %}
    <div class="page-head">
        <div class="eyebrow">{{ eyebrow }}</div>
        <h1>{{ title }}</h1>
        {% if subtitle %}<p>{{ subtitle }}</p>{% endif %}
    </div>
{% endmacro %}

{% macro kpi(label, value, sub, accent, spark) %}
    <div class="kpi" style="--accent: {{ accent|default('var(--gold)') }}">
        <span class="k-label">{{ label }}</span>
        <span class="k-val">{{ value }}</span>
        {% if sub %}<span class="k-sub">{{ sub }}</span>{% endif %}
        {% if spark %}<span class="k-spark">{{ spark|raw }}</span>{% endif %}
    </div>
{% endmacro %}

{# rows: list of maps. `field` is the value key (count for analytics, bytes/objects
   for storage). Bars are sized relative to the max in the set. fmt: compact|bytes|int|pct. #}
{% macro rank(rows, fmt, color, empty, field) %}
    {% set fmt = fmt|default('compact') %}
    {% set field = field|default('count') %}
    {% set max = 0 %}
    {% for r in rows %}{% set max = max(max, r[field]) %}{% endfor %}
    <div class="rank">
        {% for r in rows %}
            {% set val = r[field] %}
            <div class="rank-row">
                <span class="r-name" title="{{ r.name }}">{{ r.name }}</span>
                <span class="r-val">
                    {%- if fmt == 'bytes' -%}{{ val|bytes }}
                    {%- elseif fmt == 'int' -%}{{ val|number_format(0, '.', ' ') }}
                    {%- elseif fmt == 'pct' -%}{{ val|pct }}
                    {%- else -%}{{ val|compact }}{%- endif -%}
                </span>
                <div class="r-track"><div class="r-fill {{ color|default('') }}" style="width: {{ (max > 0 ? val / max * 100 : 0)|round(1) }}%"></div></div>
            </div>
        {% else %}
            <p class="dim">{{ empty|default('Aucune donnée.') }}</p>
        {% endfor %}
    </div>
{% endmacro %}

{# items: [{label, value, color}] — legend beside a donut. #}
{% macro legend(items) %}
    <div class="legend">
        {% for it in items %}
            <span class="legend-item">
                <span class="sw" style="background: {{ it.color }}"></span>
                {{ it.label }}{% if it.value is defined %} <b>{{ it.value }}</b>{% endif %}
            </span>
        {% endfor %}
    </div>
{% endmacro %}

{# grid: 7 rows (Mon..Sun) × 24 hours of ints. #}
{% macro heatmap(grid) %}
    {% set days = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
    {% set max = 0 %}
    {% for row in grid %}{% for v in row %}{% set max = max(max, v) %}{% endfor %}{% endfor %}
    <div class="heat" role="img" aria-label="Fréquentation par heure et jour de la semaine">
        <span class="h-corner"></span>
        {% for h in 0..23 %}<span class="h-col">{{ h % 6 == 0 ? h : '' }}</span>{% endfor %}
        {% for d in 0..6 %}
            <span class="h-row">{{ days[d] }}</span>
            {% for h in 0..23 %}
                {% set v = grid[d][h]|default(0) %}
                <span class="cell" style="background: {{ heat_color(v, max) }}" title="{{ days[d] }} {{ h }}h — {{ v }} vue(s)"></span>
            {% endfor %}
        {% endfor %}
    </div>
{% endmacro %}

{# Time-range pills linking to the same route with ?range=. #}
{% macro range_bar(current, ranges, route) %}
    {% set labels = { '7d': '7 j', '30d': '30 j', '90d': '90 j', 'all': 'Tout' } %}
    <div class="rangebar">
        {% for r in ranges %}
            <a href="{{ path(route, { range: r }) }}" class="{{ current == r ? 'is-active' }}">{{ labels[r]|default(r) }}</a>
        {% endfor %}
    </div>
{% endmacro %}

{# Generic data table. headers: list of strings or {label, num: true}.
   rows: list of rows; a row is a list of cells rendered by cell() below. #}
{% macro table(headers, rows, empty) %}
    {% import _self as ui %}
    <div class="tbl-wrap">
        <table class="tbl">
            <thead>
                <tr>
                    {% for h in headers %}
                        {% if h is iterable %}<th class="{{ h.num|default(false) ? 'num' }}">{{ h.label }}</th>
                        {% else %}<th>{{ h }}</th>{% endif %}
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for row in rows %}
                    <tr>{% for c in row %}{{ ui.cell(c) }}{% endfor %}</tr>
                {% else %}
                    <tr><td class="t-empty" colspan="{{ headers|length }}">{{ empty|default('Aucune donnée.') }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endmacro %}

{# Cell variants: scalar, {text, sub?}, {num}, {badge, tone?}, {badges: [{label, tone?}]},
   {chips: []}, {link: {href, label, external?}, sub?}, {html, class?} (pre-captured markup,
   e.g. action forms). #}
{% macro cell(c) %}
    {%- if c is not iterable -%}<td>{{ c }}</td>
    {%- elseif c.num is defined -%}<td class="num">{{ c.num }}</td>
    {%- elseif c.badge is defined -%}<td><span class="badge {{ c.tone|default('') }}">{{ c.badge }}</span></td>
    {%- elseif c.badges is defined -%}
        <td>{% if c.badges|length > 0 %}<span class="badges">{% for b in c.badges %}<span class="badge {{ b.tone|default('') }}">{{ b.label }}</span>{% endfor %}</span>{% else %}<span class="dim">—</span>{% endif %}</td>
    {%- elseif c.chips is defined -%}
        <td><span class="badges">{% for chip in c.chips %}<span class="chip">{{ chip }}</span>{% endfor %}</span></td>
    {%- elseif c.link is defined -%}
        <td><a href="{{ c.link.href }}"{% if c.link.external|default(false) %} target="_blank" rel="noopener"{% endif %}>{{ c.link.label }}</a>{% if c.sub|default(null) %}<span class="cell-sub">{{ c.sub }}</span>{% endif %}</td>
    {%- elseif c.html is defined -%}<td class="{{ c.class|default('') }}">{{ c.html|raw }}</td>
    {%- else -%}<td>{{ c.text|default('—') }}{% if c.sub|default(null) %}<span class="cell-sub">{{ c.sub }}</span>{% endif %}</td>
    {%- endif -%}
{% endmacro %}

{# Prev/next pagination over the same route; params carry the filter context. #}
{% macro pager(route, page, pages, params) %}
    {% if pages > 1 %}
        <nav class="pager" aria-label="Pagination">
            {% if page > 1 %}<a class="btn ghost small" href="{{ path(route, (params|default({}))|merge({ page: page - 1 })) }}">← Précédent</a>
            {% else %}<span class="btn ghost small is-disabled">← Précédent</span>{% endif %}
            <span class="pager-state num">{{ page }} / {{ pages }}</span>
            {% if page < pages %}<a class="btn ghost small" href="{{ path(route, (params|default({}))|merge({ page: page + 1 })) }}">Suivant →</a>
            {% else %}<span class="btn ghost small is-disabled">Suivant →</span>{% endif %}
        </nav>
    {% endif %}
{% endmacro %}

{# Cursor pagination for scanned feeds where the total is unknown: prev is
   page-based, next appears only while the query reported more rows (hasMore). #}
{% macro cursor_pager(route, page, hasMore, params) %}
    {% if page > 1 or hasMore %}
        <nav class="pager" aria-label="Pagination">
            {% if page > 1 %}<a class="btn ghost small" href="{{ path(route, (params|default({}))|merge({ page: page - 1 })) }}">← Précédent</a>
            {% else %}<span class="btn ghost small is-disabled">← Précédent</span>{% endif %}
            <span class="pager-state num">Page {{ page }}</span>
            {% if hasMore %}<a class="btn ghost small" href="{{ path(route, (params|default({}))|merge({ page: page + 1 })) }}">Suivant →</a>
            {% else %}<span class="btn ghost small is-disabled">Suivant →</span>{% endif %}
        </nav>
    {% endif %}
{% endmacro %}

{# Service health badge: ok|degraded|down → good|warn|bad. #}
{% macro health_badge(status) %}
    {%- set map = { ok: { tone: 'good', label: 'opérationnel' }, degraded: { tone: 'warn', label: 'dégradé' }, down: { tone: 'bad', label: 'hors ligne' } } -%}
    {%- set m = map[status]|default({ tone: 'bad', label: status }) -%}
    <span class="badge {{ m.tone }}">{{ m.label }}</span>
{% endmacro %}

{# rows: [{version, langs, types, objects}] storage completeness. #}
{% macro matrix(rows) %}
    <div class="matrix">
        {% for r in rows %}
            <div class="matrix-row">
                <span class="m-ver">{{ r.version }}</span>
                <div class="m-langs">
                    {% for l in r.langs %}<span class="lang">{{ l }}</span>{% endfor %}
                </div>
            </div>
        {% else %}
            <p class="dim">Aucune version stockée.</p>
        {% endfor %}
    </div>
{% endmacro %}
