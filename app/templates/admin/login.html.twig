{% extends 'admin/_base.html.twig' %}

{% block title %}Connexion · Admin · LODB{% endblock %}

{% block admin_body %}
    <section class="card card--auth">
        <div class="card__head" style="flex-direction: column; align-items: flex-start; gap: 0.25rem;">
            <div class="eyebrow">Accès réservé</div>
            <h1 style="font-size: 1.4rem;">Panneau d'administration</h1>
        </div>

        {% if error %}
            <p class="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
        {% endif %}

        <form method="post" action="{{ path('admin_login') }}" class="form">
            <label>
                Identifiant
                <input type="text" name="username" value="{{ last_username }}" required autofocus autocomplete="username">
            </label>
            <label>
                Mot de passe
                <input type="password" name="password" required autocomplete="current-password">
            </label>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn" style="margin-top: 0.5rem; justify-content: center;">Se connecter</button>
        </form>
    </section>
{% endblock %}
