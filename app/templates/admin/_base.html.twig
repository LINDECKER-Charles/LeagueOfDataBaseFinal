<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#0a1428">
    <title>{% block title %}Admin · LODB{% endblock %}</title>
    {# Self-contained: a committed static stylesheet (nginx-served, NOT the Vite
       build) so the ops panel keeps its styling even if the front build breaks. #}
    <link rel="preload" href="/fonts/BeaufortforLOL-Bold.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/Spiegel_TT_Regular.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/admin/admin.css">
</head>
<body>
    <header class="admin-bar">
        <span class="brand"><b>LODB</b><span>Admin</span></span>
        {% if app.user %}
            {% set route = app.request.attributes.get('_route') %}
            <nav aria-label="Navigation admin">
                <span class="nav-label">Analytics</span>
                <a href="{{ path('admin_dashboard') }}" class="{{ route == 'admin_dashboard' ? 'is-active' }}">Vue d'ensemble</a>
                <a href="{{ path('admin_traffic') }}" class="{{ route == 'admin_traffic' ? 'is-active' }}">Trafic</a>
                <a href="{{ path('admin_audience') }}" class="{{ route == 'admin_audience' ? 'is-active' }}">Audience</a>
                <a href="{{ path('admin_storage') }}" class="{{ route == 'admin_storage' ? 'is-active' }}">Stockage</a>
                <span class="nav-sep" aria-hidden="true"></span>
                <span class="nav-label">Gestion</span>
                <a href="{{ path('admin_users') }}" class="{{ route == 'admin_users' ? 'is-active' }}">Utilisateurs</a>
                <a href="{{ path('admin_builds') }}" class="{{ route == 'admin_builds' ? 'is-active' }}">Builds</a>
                <a href="{{ path('admin_donations') }}" class="{{ route == 'admin_donations' ? 'is-active' }}">Dons</a>
                <a href="{{ path('admin_api_clients') }}" class="{{ route == 'admin_api_clients' ? 'is-active' }}">Clients API</a>
                <a href="{{ path('admin_monitoring') }}" class="{{ route == 'admin_monitoring' ? 'is-active' }}">Surveillance</a>
                <a href="{{ path('admin_logs') }}" class="{{ route in ['admin_logs', 'admin_user_activity'] ? 'is-active' }}">Journal</a>
            </nav>
        {% endif %}
        <span class="spacer"></span>
        {% if app.user %}
            <a class="logout" href="{{ path('admin_logout') }}">Déconnexion</a>
        {% endif %}
    </header>

    <main class="admin-main">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="{{ label == 'success' ? 'notice' : 'alert' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        {% block admin_body %}{% endblock %}
    </main>
</body>
</html>
