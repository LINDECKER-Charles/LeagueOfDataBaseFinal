# Repo-root TEST env template — the application's test-env secrets.
# Copy to .env.test (git-ignored) and fill in. Its content becomes the ENV_TEST GitHub
# secret; CI writes it to app/.env.test.local before PHPUnit/lints. Locally:
#   cp .env.test app/.env.test.local
# Non-secret test defaults are committed in app/.env.test. See docs/github-actions-secrets.md.
# NOT a deploy target: no Caddy / registry here.

# Generate: `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`
APP_SECRET=change_me_test_secret

MINIO_SECRET_KEY=change_me_test_minio_secret

ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_test_admin

# --- PostgreSQL (user accounts, favourites, builds) ---
POSTGRES_USER=lodb
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=lodb

# --- Stripe (donations) ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
