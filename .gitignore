commande.md

# Env & secrets (see docs/github-actions-secrets.md).
# Real env files are git-ignored; committed *.example templates and the non-secret
# Symfony defaults (app/.env, app/.env.test) are not.

# Repo-root compose env — single source of truth per environment (anchored: only repo root)
/.env
/.env.test
/.env.staging
/.env.prod

# Symfony host-level secret overrides (real secrets live here locally / written by CI)
/app/.env.local
/app/.env.*.local

# Node deps anywhere outside app/ (e.g. tools/screenshots). Unanchored: matches at any depth.
node_modules/

# JetBrains IDE
.idea/
