# Repo-root env for the PRODUCTION stack (docker compose variable substitution).
# Copy to .env.prod (git-ignored) and fill in with prod-grade secrets. Bring up with:
#   docker compose --env-file .env.prod up -d
#
# The filled .env.prod is stored verbatim as the ENV_PROD GitHub Actions secret; the
# deploy job writes it to ${PROD_PATH}/.env on the server before `docker compose up`.
# See docs/github-actions-secrets.md.

# --- Image registry (GHCR) ---
REGISTRY=ghcr.io/lindecker-charles/lodb
IMAGE_TAG=prod

# --- Symfony ---
# Generate: `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`
APP_SECRET=change_me_prod_secret

# --- MinIO / object storage ---
MINIO_ROOT_USER=lodb
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET=ddragon

# --- Admin panel (protects /admin) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_strong_admin_password

# --- Caddy TLS (deploy) — DNS must point to the prod server first ---
CADDY_DOMAINS=league-of-data-base.fr, league-of-data-base.com
ACME_EMAIL=admin@league-of-data-base.fr

# --- Published ports: local runs only (ignored on the server, where Caddy owns 80/443) ---
HTTP_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025
