# Repo-root env for the PRODUCTION stack (docker compose variable substitution).
# Copy to .env.prod (git-ignored) and fill in with prod-grade secrets. Bring up with:
#   docker compose --env-file .env.prod up -d
#
# The filled .env.prod is stored verbatim as the ENV_PROD GitHub Actions secret; the
# deploy job writes it to ${PROD_PATH}/.env on the server before `docker compose up`.
# See docs/github-actions-secrets.md.

# --- Compose project (isolates this env from others on a shared host) ---
# MUST be unique per environment/project on the VPS — distinct project names give
# distinct container/network/volume namespaces, so a same-host deploy can never
# clobber another stack. Overrides the compose file's `name:` attribute.
COMPOSE_PROJECT_NAME=lodb-prod

# --- Image registry (GHCR) ---
REGISTRY=ghcr.io/lindecker-charles/lodb
IMAGE_TAG=prod

# --- Symfony ---
# Generate: `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`
APP_SECRET=change_me_prod_secret

# --- MinIO / object storage ---
MINIO_ROOT_USER=lodb
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET=ddragon

# --- Admin panel (protects /admin) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_strong_admin_password

# --- PostgreSQL (user accounts, favourites, builds) ---
POSTGRES_USER=lodb
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=lodb

# --- Stripe (donations) ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# --- Mailer (account emails: verification, password reset) ---
# A real relay is REQUIRED on served environments (no Mailpit sink here).
# Symfony DSN: smtp://USER:PASSWORD@HOST:PORT  (STARTTLS 587 | implicit TLS: smtps://...:465).
# URL-encode any special char in USER/PASSWORD. Empty/invalid = emails will fail to send.
# FROM must be on a domain whose SPF/DKIM/DMARC authorises the relay (deliverability).
MAILER_DSN=smtp://CHANGE_ME_USER:CHANGE_ME_PASSWORD@smtp.example.com:587
MAILER_FROM="LeagueOfDataBase <no-reply@league-of-data-base.com>"

# --- Public domains (deploy) — DNS must point to the host first ---
# Consumed as a caddy-docker-proxy label on nginx; the shared edge proxy
# (infra/edge) issues the Let's Encrypt cert and routes these to nginx:80.
# ACME_EMAIL lives in the edge stack's own .env, NOT here.
CADDY_DOMAINS=league-of-data-base.fr, league-of-data-base.com

# Public paid API (go-api) subdomain — routed by the SAME edge proxy, on its own
# host. DNS A record(s) for these must point to the host first. Required in deploy
# (fail-fast like CADDY_DOMAINS); dev hits go-api directly on :8090 instead.
API_CADDY_DOMAINS=api.league-of-data-base.fr, api.league-of-data-base.com

# --- Published ports: local runs only (ignored on the server, where Caddy owns 80/443) ---
HTTP_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025
