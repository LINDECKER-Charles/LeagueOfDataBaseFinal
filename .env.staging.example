# Repo-root env for the TEST stack (docker compose variable substitution).
# Copy to .env.test (git-ignored) and fill in. Bring up with:
#   docker compose --env-file .env.test up -d --build
# Ports are shifted so the test stack can run alongside dev.

# --- Image registry ---
REGISTRY=lodb
IMAGE_TAG=test

# --- Symfony ---
APP_SECRET=change_me_test_secret

# --- MinIO / object storage ---
MINIO_ROOT_USER=lodb
MINIO_ROOT_PASSWORD=change_me_test_password
MINIO_BUCKET=ddragon

# --- Admin panel (protects /admin) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_test_admin

# --- Published ports (test — shifted to avoid clashing with dev) ---
HTTP_PORT=8081
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
MAILPIT_UI_PORT=8035
