# Repo-root env for the STAGING deploy (docker compose variable substitution).
# Copy to .env.staging (git-ignored) and fill in. Its content is stored verbatim as the
# ENV_STAGING GitHub secret; the deploy job writes it to ${STAGING_PATH}/.env on the
# staging server before `docker compose ... up`. See docs/github-actions-secrets.md.

# --- Image registry (GHCR) ---
REGISTRY=ghcr.io/<owner>/lodb
IMAGE_TAG=staging

# --- Symfony ---
# Generate: `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`
APP_SECRET=change_me_staging_secret

# --- MinIO / object storage ---
MINIO_ROOT_USER=lodb
MINIO_ROOT_PASSWORD=change_me_staging_password
MINIO_BUCKET=ddragon

# --- Admin panel (protects /admin) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_staging_admin

# --- Caddy TLS (deploy) — DNS must point to the staging server first ---
CADDY_DOMAINS=test.league-of-data-base.com
ACME_EMAIL=admin@league-of-data-base.fr

# --- Published ports: local runs only (ignored on the server, where Caddy owns 80/443) ---
HTTP_PORT=8081
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
MAILPIT_UI_PORT=8035
