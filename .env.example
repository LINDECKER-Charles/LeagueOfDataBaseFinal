# Repo-root env for docker compose variable substitution.
# Copy to .env (git-ignored) and fill in. Secrets are documented in docs/github-actions-secrets.md.

# --- Image registry (local dev) ---
# Dev builds images locally via compose.override.yaml, so these are mostly cosmetic here.
# Deploy hosts set REGISTRY/IMAGE_TAG in .env.staging / .env.prod (see those *.example).
REGISTRY=ghcr.io/lindecker-charles/lodb
IMAGE_TAG=latest

# --- Symfony ---
# Generate: `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`
APP_SECRET=change_me_dev_secret

# --- MinIO / object storage ---
MINIO_ROOT_USER=lodb
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET=ddragon

# --- Admin panel (protects /admin) ---
# Plaintext credentials for the single admin identity.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_admin_password

# --- PostgreSQL (user accounts, favourites, builds) ---
POSTGRES_USER=lodb
POSTGRES_PASSWORD=lodb
POSTGRES_DB=lodb

# --- Stripe (donations) ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# --- Contact form ---
# Mailbox that receives footer contact-form submissions (bug/feedback/review/sales).
# Empty = submissions still land in the /admin inbox but no email is sent (dev: Mailpit :8025).
CONTACT_RECIPIENT=

# --- Published ports (dev) ---
HTTP_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025
