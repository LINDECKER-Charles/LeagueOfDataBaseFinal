# Repo-root env for docker compose variable substitution.
# Copy to .env (git-ignored) and fill in. Secrets are documented in docs/github-actions-secrets.md.

# --- Image registry (deploy) ---
# Images are published as ${REGISTRY}/{app,nginx,go-fetcher}. CI pushes to ghcr.io/<owner>/lodb.
# IMAGE_TAG selects which promoted tag this host runs: `staging` (staging server) or
# `prod` (prod server). CI builds :<sha>+:staging on dev, then retags :staging->:prod on main.
REGISTRY=ghcr.io/lindecker-charles/lodb
IMAGE_TAG=staging

# --- Symfony ---
# Generate: `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`
APP_SECRET=change_me_dev_secret

# --- MinIO / object storage ---
MINIO_ROOT_USER=lodb
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET=ddragon

# --- Admin panel (protects /admin) ---
# Plaintext credentials for the single admin identity.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_admin_password

# --- Reverse proxy / TLS (deployed hosts — consumed by compose.deploy.yaml) ---
# Caddy terminates HTTPS and auto-provisions Let's Encrypt certs for these domains.
# Comma-separated. DNS (A/AAAA) for EACH must already point to this server at first
# deploy, and ports 80/443 must be reachable, or ACME issuance fails (Caddy retries).
#   staging host: CADDY_DOMAINS=test.league-of-data-base.com
#   prod host:    CADDY_DOMAINS=league-of-data-base.fr, league-of-data-base.com
CADDY_DOMAINS=league-of-data-base.fr, league-of-data-base.com
ACME_EMAIL=admin@league-of-data-base.fr

# Reverse-proxy trust for Symfony (optional override; default 127.0.0.1,REMOTE_ADDR
# is correct for the Caddy -> nginx -> php-fpm Docker chain).
# TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR

# --- Published ports (dev only; prod publishes 80/443 via Caddy) ---
HTTP_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025
