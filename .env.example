# Repo-root env for docker compose variable substitution.
# Copy to .env (git-ignored) and fill in. Secrets are documented in SECRET_CONFIG.md.

# --- Image registry (prod deploy) ---
# Images are published as ${REGISTRY}/{app,nginx,go-fetcher}. CI pushes to ghcr.io/<owner>/lodb.
REGISTRY=ghcr.io/lindecker-charles/lodb
IMAGE_TAG=latest

# --- Symfony ---
# Generate: `php -r 'echo bin2hex(random_bytes(16)), PHP_EOL;'`
APP_SECRET=change_me_dev_secret

# --- MinIO / object storage ---
MINIO_ROOT_USER=lodb
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET=ddragon

# --- Published ports (dev) ---
HTTP_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025
