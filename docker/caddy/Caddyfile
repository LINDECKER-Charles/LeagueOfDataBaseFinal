# Public TLS entrypoint for LODB (prod).
# Terminates HTTPS with automatic Let's Encrypt certificates (HTTP-01 / TLS-ALPN),
# redirects HTTP -> HTTPS, serves HTTP/3, and reverse-proxies to the internal nginx.
# Domains + ACME contact are injected from the environment (compose -> .env):
#   CADDY_DOMAINS  e.g. "league-of-data-base.fr, league-of-data-base.com"
#   ACME_EMAIL     Let's Encrypt contact address
#
# reverse_proxy sets X-Forwarded-{For,Proto,Host} automatically; nginx relays them
# to php-fpm, and Symfony trusts them (framework.trusted_proxies) to build https URLs.

{
	email {$ACME_EMAIL}
}

{$CADDY_DOMAINS} {
	reverse_proxy nginx:80
}
